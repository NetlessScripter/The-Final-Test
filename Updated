-- MAIN RENDER LOOP
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local giCursor       = 1
local lastGITime     = 0
local lastSSSTime    = 0
local lastCausticScan = 0
local accumPost      = 0

RunService.RenderStepped:Connect(function(dt)
    local now    = tick()
    local char   = player.Character
    local camCF  = camera.CFrame
    local camPos = camCF.Position
    local sunDir = Lighting:GetSunDirection()

    if char then
        worldParams.FilterDescendantsInstances = { probeRoot, char }
    end

    -- ── GI PATH TRACING (distributed across frames)
    if now - lastGITime >= CFG.GI_UPDATE_INTERVAL then
        lastGITime = now

        for i = 1, CFG.GI_RAYS_PER_FRAME do
            local slotIdx = ((giCursor - 1 + i - 1) % CFG.MAX_GI_PROBES) + 1
            local rayDir
            if slotIdx % 3 == 0 then
                -- Sun-importance sample: bias toward sun for better direct GI
                rayDir = sunJitter(
                    (sunDir + fibDir(slotIdx, CFG.MAX_GI_PROBES, camCF) * 0.6).Unit
                )
            else
                -- Cosine-weighted from camera hemisphere
                rayDir = fibDir(slotIdx, CFG.MAX_GI_PROBES, camCF)
                rayDir = (rayDir - camCF.UpVector * 0.15).Unit
            end
            tracePath(camPos, rayDir, sunDir, char, slotIdx)
        end

        giCursor = ((giCursor + CFG.GI_RAYS_PER_FRAME - 1) % CFG.MAX_GI_PROBES) + 1
    end

    -- ── SPECULAR REFLECTIONS (every frame)
    updateSpecular(camCF, char, sunDir)

    -- ── DEPTH OF FIELD (every frame)
    if CFG.DOF_ENABLED then
        local ex = char and { char } or nil
        updateDoF(camCF, ex)
    end

    -- ── CAUSTICS (animate every frame, scan every 3s)
    if CFG.CAUSTIC_ENABLED then
        tickCaustics(dt, sunDir)
        if now - lastCausticScan >= 3.0 then
            lastCausticScan = now
            scanForCausticPositions(char)
        end
    end

    -- ── EMISSIVE / LAVA FLICKER (every frame)
    if CFG.EMISSIVE_ENABLED then
        tickEmissiveFlicker(dt)
    end

    -- ── POST FX (every 0.4s)
    accumPost += dt
    if accumPost >= 0.4 then
        accumPost = 0
        updatePostFX()
    end

    -- ── EMISSIVE SCAN (every 1.8s)
    if CFG.EMISSIVE_ENABLED and now - lastSSSTime >= 1.8 then
        lastSSSTime = now
        updateSSS(char)
    end
end)


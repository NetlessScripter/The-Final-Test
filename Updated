    clearSSS()
    for i = 1, CFG.MAX_GI_PROBES  do giLights[i].Brightness  = 0 end
    for i = 1, CFG.SPEC_RAYS      do specLights[i].Brightness = 0 end
    for i = 1, CFG.CAUSTIC_PROBES do
        causticLights[i].Brightness = 0
        causticOrigins[i] = nil

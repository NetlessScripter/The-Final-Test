-- ADAPTIVE BLOOM & COLOR GRADING (unchanged)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function updatePostFX()
    local sunDir = Lighting:GetSunDirection()
    local elev   = math.clamp(sunDir.Y, -1, 1)
    local t      = (elev + 1) / 2

    local goldenT   = 1 - math.abs(elev - 0.18) / 0.22
    goldenT         = math.clamp(goldenT, 0, 1)
    bloom.Intensity = CFG.BLOOM_BASE + goldenT * CFG.BLOOM_SUNSET_BOOST
    bloom.Threshold = 0.88 + t * 0.08

    sunRays.Intensity = math.clamp(0.05 + (1-t) * 0.35, 0.02, 0.38)
    sunRays.Spread    = 0.45 + (1-t) * 0.2

    if elev < 0.0 then
        cc.TintColor  = Color3.fromRGB(150, 168, 220)
        cc.Saturation = -0.1
        cc.Contrast   = 0.05
        cc.Brightness = -0.02
    elseif elev < 0.2 then
        local g = elev / 0.2
        cc.TintColor  = Color3.new(1, 0.82 + g*0.06, 0.55 + g*0.35)
        cc.Saturation = 0.28 + (1-g) * 0.22
        cc.Contrast   = 0.18 + (1-g) * 0.06
        cc.Brightness = 0.01
    else
        cc.TintColor  = Color3.fromRGB(255, 248, 234)
        cc.Saturation = 0.16
        cc.Contrast   = 0.13
        cc.Brightness = 0.025
    end

    atmo.Haze    = CFG.ATMOSPHERE_HAZE - t * 0.5
    atmo.Density = CFG.ATMOSPHERE_DENSITY - t * 0.05

    Lighting.OutdoorAmbient = lerpColor(
        Color3.fromRGB(50, 60, 110),
        Color3.fromRGB(80, 92, 118),
        t
    )
end


local rand = Random.new()

local function lerpColor(a, b, t)
    t = math.clamp(t, 0, 1)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function mulColor(c, s)
    return Color3.new(
        math.clamp(c.R * s, 0, 1),
        math.clamp(c.G * s, 0, 1),
        math.clamp(c.B * s, 0, 1)
    )
end

-- Perceptual luminance (ITU-R BT.709 weights)
local function colorLum(c)
    return 0.2126 * c.R + 0.7152 * c.G + 0.0722 * c.B
end

-- Cosine-weighted hemisphere sample aligned to surface normal.
-- This is correct importance sampling for Lambertian diffuse BRDF —
-- the PDF is cos(θ)/π which cancels the cos(θ) in the rendering equation.
local function hemisphereDir(normal)
    local u1  = rand:NextNumber()
    local u2  = rand:NextNumber()
    local r   = math.sqrt(u1)
    local phi = 2 * math.pi * u2
    local x   = r * math.cos(phi)
    local z   = r * math.sin(phi)
    local y   = math.sqrt(math.max(0, 1 - u1))
    local up      = math.abs(normal.Y) < 0.99 and Vector3.new(0,1,0) or Vector3.new(1,0,0)
    local tangent  = normal:Cross(up).Unit
    local bitangent = normal:Cross(tangent).Unit
    return (tangent * x + normal * y + bitangent * z).Unit
end

-- Reflect ray around normal
local function reflect(dir, normal)
    return dir - 2 * dir:Dot(normal) * normal
end

-- Fibonacci lattice direction for uniform sphere/hemisphere coverage
local function fibDir(n, total, basis)
    local golden = (1 + math.sqrt(5)) / 2
    local theta  = 2 * math.pi * n / golden
    local cosP   = 1 - 2 * (n + 0.5) / total
    local sinP   = math.sqrt(math.max(0, 1 - cosP * cosP))
    local x = sinP * math.cos(theta)
    local y = math.abs(cosP)
    local z = sinP * math.sin(theta)
    if basis then
        return (basis.RightVector * x + basis.UpVector * y + basis.LookVector * z).Unit
    end
    return Vector3.new(x, y, z).Unit
end

-- ── SCHLICK FRESNEL APPROXIMATION
-- Physics: at grazing angles ALL surfaces become mirrors.
-- F(θ) = F₀ + (1 - F₀) × (1 - cosθ)⁵
-- F₀ = base reflectivity at normal incidence (0°)
--   Dielectrics: ~0.04  |  Metals: use albedo as F₀
-- cosθ = dot(viewDir, halfwayVector) or dot(viewDir, normal)
local function schlickFresnel(cosTheta, F0)
    local t  = math.max(0, 1 - cosTheta)
    local t5 = t * t * t * t * t   -- (1 - cosθ)⁵
    return F0 + (1 - F0) * t5
end

-- ── GGX / TROWBRIDGE-REITZ NORMAL DISTRIBUTION FUNCTION
-- Physics: describes statistical distribution of microfacet normals on a surface.
-- α = roughness² (perceptual roughness squared — makes linear roughness feel linear)
-- D(H) = α² / (π × ((N·H)²(α²-1)+1)²)
-- Higher D at N·H=1 (smooth) — microfacets concentrate around the macro normal
local function ggxD(NdotH, alpha)
    local a2 = alpha * alpha
    local d  = NdotH * NdotH * (a2 - 1) + 1
    return a2 / (math.pi * d * d + 1e-6)
end

-- ── SMITH GGX GEOMETRY MASKING-SHADOWING (G1)
-- Physics: probability that a microfacet with given slope is not masked (from view)
-- or shadowed (from light). Smith separates view and light into independent G1 terms.
-- G(V, L) = G1(V) × G1(L)
local function smithG1GGX(cosAngle, alpha)
    local a2  = alpha * alpha
    local c2  = cosAngle * cosAngle
    -- Numerically stable form
    return (2 * cosAngle) / (cosAngle + math.sqrt(a2 + (1 - a2) * c2) + 1e-6)
end

-- ── GGX VISIBLE NORMAL DISTRIBUTION FUNCTION SAMPLING
-- Physics: importance-sample the GGX half-vector distribution aligned to normal.
-- Returns: reflected ray direction, half-vector H, cosine(view·H)
-- This is the correct way to generate specular ray directions — concentrates samples
-- in the specular lobe rather than wasting them on near-zero BRDF regions.
-- References: Heitz 2014, Walter et al. 2007
local function sampleGGX(roughness, normal, viewDir)
    local alpha = roughness * roughness   -- perceptual → linear roughness
    local u1    = rand:NextNumber()
    local u2    = rand:NextNumber()

    -- Sample half-vector from GGX distribution in local tangent space
    local phi      = 2 * math.pi * u1
    -- Spherical coords: cos(θ_h) from GGX inversion
    local cosThH   = math.sqrt((1 - u2) / math.max(1e-6, 1 + (alpha*alpha - 1) * u2))
    local sinThH   = math.sqrt(math.max(0, 1 - cosThH*cosThH))

    -- Build orthonormal tangent frame
    local up       = math.abs(normal.Y) < 0.99 and Vector3.new(0,1,0) or Vector3.new(1,0,0)
    local T        = normal:Cross(up).Unit
    local B        = normal:Cross(T).Unit

    -- Half-vector in world space
    local H = (T * (sinThH * math.cos(phi))
             + normal * cosThH
             + B * (sinThH * math.sin(phi))).Unit

    -- Reflect view direction around H to get the sample direction
    local cosVH    = math.max(0, -viewDir:Dot(H))
    local reflDir  = (viewDir + 2 * cosVH * H).Unit
    return reflDir, H, cosVH
end

-- ── STRATIFIED 2D JITTER
-- Returns jittered (u,v) in [0,1)² using a sqrt(n)×sqrt(n) stratified grid.
-- Physics justification: stratified sampling reduces variance by ensuring no
-- "clumping" of random samples — each cell gets exactly one sample.
-- Used for shadow ray stratification.
local stratTable  = {}   -- pre-computed stratum order
local stratCount  = 0
local function nextStratified(n)
    stratCount = stratCount + 1
    if stratCount > n then stratCount = 1 end
    local side = math.ceil(math.sqrt(n))
    local row  = math.floor((stratCount - 1) / side)
    local col  = (stratCount - 1) % side
    local u    = (col + rand:NextNumber()) / side
    local v    = (row + rand:NextNumber()) / side
    return u, v
end

-- ── PREETHAM / HOSEK-WILKIE INSPIRED SKY RADIANCE
-- Physics: Real sky colour is dominated by two scattering modes:
--   • Rayleigh scattering: molecules (N₂, O₂) scatter short wavelengths ∝ 1/λ⁴
--     → blue sky, red sunsets (long path through atmosphere at horizon)
--   • Mie scattering: aerosols (dust, water droplets) scatter all wavelengths roughly equally
--     → white halo around the sun (forward-scattering peak)
-- Night: star field approximated with pseudo-random noise pattern.
-- Moon: single bright spot opposite sun elevation during night.
local function skyRadiance(dir, sunDir)
    local sunElev = sunDir.Y
    local sunDot  = math.max(0, dir:Dot(sunDir))
    local zenith  = math.max(0, dir.Y)   -- 0=horizon, 1=straight up

    if sunElev >= -0.12 then
        -- ── DAYTIME / TWILIGHT ────────────────────────────────────
        local dayT = math.clamp(sunElev / 0.30, 0, 1)  -- 0=horizon, 1=full day

        -- Turbidity-based horizon chromaticity (low sun → deep orange/red at horizon near sun)
        local horizSunward  = 0.55 + sunDot * 0.42   -- reddish-orange near sun at horizon
        local horizAway     = 0.38 + sunDot * 0.08   -- cooler away from sun
        local hR = horizSunward
        local hG = 0.36 + sunDot * 0.16 - (1-dayT)*0.12
        local hB = 0.22 - sunDot * 0.10 + dayT * 0.12

        -- Zenith chromaticity — deep Rayleigh blue at noon, steel blue at dawn
        local zR = 0.10 * dayT + 0.05 * (1-dayT)
        local zG = 0.28 * dayT + 0.10 * (1-dayT)
        local zB = 0.92 * dayT + 0.32 * (1-dayT)

        -- Quadratic zenith blend matches real sky gradient curvature
        local t2 = zenith * zenith
        local sR = hR + (zR - hR) * t2
        local sG = hG + (zG - hG) * t2
        local sB = hB + (zB - hB) * t2

        -- Mie forward scattering: bright halo tightly concentrated around the sun disk
        -- Real sun subtends 0.5°; we exaggerate to ~8° for artistic impression
        local mie        = sunDot ^ 18 * 0.85 * dayT  -- tight peak
        local mieCorona  = sunDot ^ 5  * 0.22 * dayT  -- wider glow
        sR = sR + mie + mieCorona
        sG = sG + mie * 0.78 + mieCorona * 0.65
        sB = sB + mie * 0.30 + mieCorona * 0.45

        -- Twilight band: purple/magenta anti-solar arch at low sun
        if sunElev < 0.15 then
            local tw = (0.15 - sunElev) / 0.27    -- 0 at day, 1 at night
            local antiSunDot = math.max(0, -dir:Dot(sunDir))
            local arch = antiSunDot^2 * (1-zenith) * tw * 0.28
            sR = sR + arch * 0.60
            sG = sG + arch * 0.18
            sB = sB + arch * 0.45
        end

        return Color3.new(math.clamp(sR,0,1), math.clamp(sG,0,1), math.clamp(sB,0,1))

    else
        -- ── NIGHT ─────────────────────────────────────────────────
        local nT = math.clamp(-sunElev / 0.30, 0, 1)   -- 0=dusk, 1=full night

        -- Dark blue-indigo sky base
        local skyR = math.max(0, 0.035 - nT * 0.025)
        local skyG = math.max(0, 0.045 - nT * 0.030)
        local skyB = math.max(0, 0.14  - nT * 0.05 + zenith * 0.04)

        -- Horizon glow from light pollution / remaining twilight
        local horizGlow = (1 - zenith) * (1 - nT) * 0.08
        skyR = skyR + horizGlow * 0.55
        skyG = skyG + horizGlow * 0.38

        -- Stars: pseudo-random field using hashed dir components
        -- High-frequency hash → sparse bright dots (star-like)
        local sx = math.floor(dir.X * 28 + 0.5)
        local sy = math.floor(dir.Y * 28 + 0.5)
        local sz = math.floor(dir.Z * 28 + 0.5)
        local hash = math.sin(sx * 127.1 + sy * 311.7 + sz * 74.7) * 43758.5
        hash = hash - math.floor(hash)
        local star = math.max(0, hash - 0.972) * 34.0   -- only top ~2.8% of hash → stars
        star = star * star * nT * math.max(0, dir.Y)    -- only upward, brighter at full night
        skyR = skyR + star
        skyG = skyG + star * 0.92
        skyB = skyB + star * 0.85

        -- Moon: bright spot opposite sun direction, slightly above horizon
        local moonDir  = Vector3.new(-sunDir.X, math.abs(sunDir.Y) * 0.6 + 0.3, -sunDir.Z).Unit
        local moonDot  = math.max(0, dir:Dot(moonDir))
        local moon     = moonDot ^ 220 * 1.8 * nT    -- tiny disk
        local moonGlow = moonDot ^ 12 * 0.12 * nT    -- soft halo
        skyR = skyR + moon * 0.95 + moonGlow * 0.88
        skyG = skyG + moon * 0.95 + moonGlow * 0.92
        skyB = skyB + moon * 1.00 + moonGlow * 1.00

        return Color3.new(math.clamp(skyR,0,1), math.clamp(skyG,0,1), math.clamp(skyB,0,1))
    end
end


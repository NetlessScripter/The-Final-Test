const ws={slot:0,wpns:WPNS.map(w=>({...w})),lastFire:0,reloading:false};
function wSel(i){if(i<0||i>=ws.wpns.length)return;ws.slot=i;updBar();showWpnName(ws.wpns[i].name)}
function wScroll(d){let n=ws.slot+(d>0?1:-1);if(n>=ws.wpns.length)n=0;if(n<0)n=ws.wpns.length-1;wSel(n)}
function wFire(){
  const now=Date.now(),w=ws.wpns[ws.slot];
  if(now-ws.lastFire<w.fr||w.ammo<=0||ws.reloading)return;
  ws.lastFire=now;w.ammo--;

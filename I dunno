}
function wReload(){
  if(ws.reloading)return;
  const w=ws.wpns[ws.slot],base=WPNS[ws.slot].ammo;
  if(w.rsv<=0||w.ammo===base)return;
  ws.reloading=true;notify('↺ RELOADING...');
  setTimeout(()=>{
    const need=base-w.ammo,xfer=Math.min(need,w.rsv);
    w.ammo+=xfer;w.rsv-=xfer;ws.reloading=false;
    document.getElementById('am').textContent=w.ammo;
    document.getElementById('ar').textContent='/ '+w.rsv;
    updBar();
  },1700)
}

// ── Camera Controller ────────────────────────────────────
// THE CROWN JEWEL: Spring-based TPS camera
// Features:
//   1. Drag catch-up easing (spring on yaw/pitch)
//   2. Multi-layer sway (breathing + walk bob + strafe roll + sprint lean)
//   3. Soft arm position spring (position floats toward player)
//   4. Landing impact punch
//   5. Recoil springs (auto-return)
//   6. ADS / sprint FOV springs
//   7. Camera strafe tilt (Z-axis roll)
//   8. Look-ahead (leads movement direction)
//   9. Camera collision pull-in
//  10. Muzzle flash position
class CamCtrl {
  constructor(camera,collidables){
    this.cam=camera;this.col=collidables;

    // ── Rotation springs (THE drag catch-up easing) ──
    // targetYaw/Pitch = where mouse wants to go
    // springs ease current toward target — feels like dragging through silk
    this.yawSp=new Sp(cfg.springK,Math.sqrt(cfg.springK)*2.1);
    this.pitchSp=new Sp(cfg.springK,Math.sqrt(cfg.springK)*2.1);
    this.tgtYaw=0;this.tgtPitch=-.14;
    this.yawSp.snap(0);this.pitchSp.snap(-.14);

    // ── Arm position spring (softer, gives floaty body follow) ──
    this.armSp=new Sp3(72,13);

    // ── Offset springs (ADS transition) ──
    this.offSp=new Sp3(200,28);
    this.baseOff=new THREE.Vector3(.62,1.68,-3.1);
    this.adsOff =new THREE.Vector3(.24,1.56,-1.55);
    this.offSp.snap(.62,1.68,-3.1);

    // ── Sway springs ──
    this.rollSp=new Sp(48,8.5);   // strafe Z-roll
    this.bobSp =new Sp(55,9);     // walk/sprint vertical bob
    this.leanSp=new Sp(42,7.5);   // sprint forward lean
    this.tiltSp=new Sp(52,10);    // lateral camera tilt

    // ── Recoil springs ──
    this.recP=new Sp(260,21);     // pitch kick
    this.recY=new Sp(210,18);     // yaw kick

    // ── Landing impact spring ──
    this.landSp=new Sp(340,24);

    // ── FOV spring ──
    this.fovSp=new Sp(130,22);this.fovSp.snap(cfg.fov);

    // ── Look-ahead springs ──
    this.laX=new Sp(28,7);this.laZ=new Sp(22,6.5);

    // State
    this.isADS=false;this.isSprint=false;this.wasGround=true;
    this.swayT=0;this.breathT=0;this.rc=new THREE.Raycaster();
  }

  applyMouse(dx,dy){
    const s=cfg.sens*.00148,am=this.isADS?cfg.adsMult:1,iy=cfg.invertY?-1:1;
    this.tgtYaw-=dx*s*am;
    this.tgtPitch-=dy*s*am*iy;
    this.tgtPitch=Math.max(-1.08,Math.min(.65,this.tgtPitch));
  }

  addRecoil(rp,ry){
    this.recP.tgt+=rp;this.recY.tgt+=(Math.random()-.5)*ry*2;
    setTimeout(()=>{this.recP.tgt*=.25;this.recY.tgt*=.25},85);
  }

  land(spd){this.landSp.tgt=-Math.min(spd*.016,.085);setTimeout(()=>this.landSp.tgt=0,110)}

  setADS(v){
    this.isADS=v;
    this.fovSp.tgt=v?cfg.fov-23:cfg.fov;
    document.getElementById('av').classList.toggle('on',v);
    document.getElementById('xh').classList.toggle('ads',v);
  }
  setSprint(v){
    this.isSprint=v;
    if(!this.isADS)this.fovSp.tgt=v?cfg.fov+9:cfg.fov;
  }

  update(dt,ppos,pvel,grounded){
    // Landing detection
    if(this.wasGround===false&&grounded)this.land(Math.abs(pvel.y));
    this.wasGround=grounded;

    // ── Drag catch-up: spring stiffness from cfg ──
    this.yawSp.k=cfg.springK;this.yawSp.d=Math.sqrt(cfg.springK)*2.1;
    this.pitchSp.k=cfg.springK;this.pitchSp.d=Math.sqrt(cfg.springK)*2.1;
    this.yawSp.tgt=this.tgtYaw;this.pitchSp.tgt=this.tgtPitch;
    const Y=this.yawSp.tick(dt),P=this.pitchSp.tick(dt);

    // Recoil auto-decay
    this.recP.tgt*=Math.pow(.9,dt*60);this.recY.tgt*=Math.pow(.9,dt*60);
    const rP=this.recP.tick(dt),rY=this.recY.tick(dt);

    // ── Arm position spring ──
    this.armSp.tgt(ppos.x,ppos.y,ppos.z);
    const ap=this.armSp.tick(dt);
    const armPos=new THREE.Vector3(ap.x,ap.y,ap.z);

    // ── FOV ──
    this.cam.fov=this.fovSp.tick(dt);this.cam.updateProjectionMatrix();

    // ── Sway system ──
    const swayOn=cfg.sway;
    const spd2=pvel.x*pvel.x+pvel.z*pvel.z;
    const moving=spd2>.18,sprint=this.isSprint;
    this.swayT+=dt;this.breathT+=dt*.82;

    // Strafe roll (Z)
    const strafeSide=pvel.x;
    this.rollSp.tgt=strafeSide*(sprint?.03:.018)*(swayOn?1:0);
    const roll=this.rollSp.tick(dt);

    // Vertical bob (Y) — dual frequency: slower for walk, faster for sprint
    const bobFreq=sprint?11.2:6.8,bobAmp=sprint?.038:.018;
    this.bobSp.tgt=moving?Math.sin(this.swayT*bobFreq)*bobAmp*(swayOn?1:0):0;
    const bob=this.bobSp.tick(dt);

    // Forward lean (sprint tilts camera slightly forward)
    this.leanSp.tgt=sprint?.042:0;
    const lean=this.leanSp.tick(dt);

    // Camera tilt (separate from position sway — pure rotation roll)
    this.tiltSp.tgt=-strafeSide*(sprint?.038:.022)*(swayOn?1:0);
    const tilt=this.tiltSp.tick(dt);

    // Breathing (always present, very subtle — makes scene feel alive)
    const bx=Math.cos(this.breathT*.73)*.0022,by=Math.sin(this.breathT)*.0032;

    // Landing impact
    const land=this.landSp.tick(dt);
    this.landSp.tgt*=Math.pow(.82,dt*60);

    // Look-ahead (camera leads movement direction slightly — GTA V / RDR2 trick)
    this.laX.tgt=pvel.x*.115*(sprint?1.45:1);
    this.laZ.tgt=pvel.z*.04;
    const lax=this.laX.tick(dt),laz=this.laZ.tick(dt);

    // ── Offset spring (ADS/base) ──
    const to=this.isADS?this.adsOff:this.baseOff;
    this.offSp.tgt(to.x,to.y,to.z);
    const off=this.offSp.tick(dt);

    // ── Build camera transform ──
    const qY=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,1,0),Y+rY);
    const qP=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(1,0,0),P+rP+lean*.28);
    const qR=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,0,1),tilt);

    // Offset: shoulder position + look-ahead + breathing + bob + landing
    const offV=new THREE.Vector3(
      off.x+lax+bx,
      off.y+bob+by+land,
      off.z
    ).applyQuaternion(qY);

    const want=armPos.clone().add(offV);

    // ── Camera collision pull-in ──
    const final=this.collide(armPos,want);
    this.cam.position.copy(final);

    // Apply full rotation
    this.cam.quaternion.copy(qY).multiply(qP).multiply(qR);
    // Extra sway rotation post-set
    const qBob=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(1,0,0),bob*.25+land*.38);
    const qRoll=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,1,0),roll*.4);
    this.cam.quaternion.multiply(qBob).multiply(qRoll);

    return{yaw:Y,pitch:P};
  }

  collide(origin,want){
    const dir=want.clone().sub(origin);
    const dist=dir.length();if(dist<.01)return want;
    this.rc.set(origin,dir.clone().normalize());this.rc.far=dist;
    const h=this.rc.intersectObjects(this.col,false);
    if(h.length){
      const safe=h[0].point.clone().sub(dir.normalize().multiplyScalar(.18));
      return safe;
    }
    return want;
  }

  getFwd(){
    return new THREE.Vector3(0,0,-1).applyQuaternion(
      new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,1,0),this.yawSp.val))
  }
  getRight(){
    return new THREE.Vector3(1,0,0).applyQuaternion(
      new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,1,0),this.yawSp.val))
  }
}

// ── Player Controller ────────────────────────────────────
class Player {
  constructor(col){
    this.col=col;this.pos=new THREE.Vector3(0,0,5);
    this.vel=new THREE.Vector3();this.mesh=null;
    // Movement
    this.wSpd=5.4;this.sSpd=9.8;this.cSpd=2.6;this.jFrc=7.2;this.grav=-21;
    this.acc=17;this.fric=11;this.air=.33;
    // State
    this.grnd=false;this.sprt=false;this.crouch=false;
    this.jumping=false;this.mantling=false;this.canMnt=false;
    this.mntTgt=new THREE.Vector3();this.mntSt=new THREE.Vector3();this.mntPrg=0;
    this.prevGrnd=false;this.onLand=null;
    this.ry=new THREE.Raycaster();this.rf=new THREE.Raycaster();this.rm=new THREE.Raycaster();
    // Health
    this.hp=100;this.shield=75;
  }

  setMesh(m){this.mesh=m}

  update(dt){
    if(this.mantling){this._mantle(dt);return}
    const fwd=camCtrl.getFwd().setY(0).normalize();
    const right=camCtrl.getRight().setY(0).normalize();
    this.sprt=(K.ShiftLeft||K.ShiftRight)&&K.KeyW&&this.grnd;
    this.crouch=(K.ControlLeft||K.ControlRight)&&this.grnd;
    const spd=this.sprt?this.sSpd:this.crouch?this.cSpd:this.wSpd;
    const accel=this.grnd?this.acc:this.acc*this.air;

    let dir=new THREE.Vector3();
    if(K.KeyW)dir.addScaledVector(fwd,1);
    if(K.KeyS)dir.addScaledVector(fwd,-1);
    if(K.KeyA)dir.addScaledVector(right,-1);
    if(K.KeyD)dir.addScaledVector(right,1);
    if(dir.length())dir.normalize();

    this.vel.x+=dir.x*accel*dt;this.vel.z+=dir.z*accel*dt;
    const hs=Math.hypot(this.vel.x,this.vel.z);
    if(hs>spd){this.vel.x*=spd/hs;this.vel.z*=spd/hs}

    // Friction
    if(this.grnd){const fr=1-Math.min(1,this.fric*(dir.length()?.28:1)*dt);this.vel.x*=fr;this.vel.z*=fr}

    // Gravity
    if(!this.grnd)this.vel.y+=this.grav*dt;

    // Jump
    if(K.Space&&this.grnd&&!this.jumping){
      this.vel.y=this.jFrc;this.grnd=false;this.jumping=true;
      setTimeout(()=>this.jumping=false,280);
    }

    // Mantle check
    this._checkMantle();
    if(this.canMnt&&K.KeyF)this._startMantle();

    this.pos.addScaledVector(this.vel,dt);
    this._groundCheck();
    if(!this.prevGrnd&&this.grnd){if(this.onLand)this.onLand(Math.abs(this.vel.y));this.vel.y=0}
    this.prevGrnd=this.grnd;
    if(this.vel.y>0)this._ceilCheck();
    if(this.mesh){
      this.mesh.position.copy(this.pos);
      if(this.vel.length()>.4){
        const a=Math.atan2(this.vel.x,this.vel.z);
        this.mesh.rotation.y+=( a-this.mesh.rotation.y)*Math.min(1,10*dt);
      }
    }
  }

  _groundCheck(){
    const o=this.pos.clone().add(new THREE.Vector3(0,.12,0));
    this.ry.set(o,new THREE.Vector3(0,-1,0));this.ry.far=.35;
    const h=this.ry.intersectObjects(this.col,false);
    if(h.length&&this.pos.y<=h[0].point.y+.04){
      this.pos.y=h[0].point.y;if(this.vel.y<0)this.vel.y=0;this.grnd=true;
    } else this.grnd=false;
  }

  _ceilCheck(){
    const o=this.pos.clone().add(new THREE.Vector3(0,1.7,0));
    this.ry.set(o,new THREE.Vector3(0,1,0));this.ry.far=.28;
    if(this.ry.intersectObjects(this.col,false).length)this.vel.y=Math.min(0,this.vel.y);
  }

  _checkMantle(){
    const fwd=new THREE.Vector3(Math.sin(camCtrl.yawSp.val),0,Math.cos(camCtrl.yawSp.val)).negate();
    const chest=this.pos.clone().add(new THREE.Vector3(0,.9,0));
    this.rf.set(chest,fwd);this.rf.far=1.75;
    const h=this.rf.intersectObjects(this.col,false);
    if(h.length&&!this.grnd){
      const topO=new THREE.Vector3(h[0].point.x,h[0].point.y+1.6,h[0].point.z);
      this.rm.set(topO,new THREE.Vector3(0,-1,0));this.rm.far=2.2;
      const th=this.rm.intersectObjects(this.col,false);
      if(th.length){
        const dh=th[0].point.y-this.pos.y;
        if(dh>.25&&dh<2.6){
          this.canMnt=true;
          this.mntTgt.set(topO.x+fwd.x*.55,th[0].point.y+.05,topO.z+fwd.z*.55);
          return;
        }
      }
    }
    this.canMnt=false;
  }

  _startMantle(){
    this.mantling=true;this.mntPrg=0;this.mntSt.copy(this.pos);
    this.vel.set(0,0,0);notify('◆ MANTLED');
  }

  _mantle(dt){
    this.mntPrg=Math.min(1,this.mntPrg+dt*2.8);
    const t=1-Math.pow(1-this.mntPrg,3); // ease-out cubic
    this.pos.lerpVectors(this.mntSt,this.mntTgt,t);
    if(this.mesh)this.mesh.position.copy(this.pos);
    if(this.mntPrg>=1){this.mantling=false;this.grnd=true;this.vel.set(0,0,0)}
  }
}

// ── World Builder ────────────────────────────────────────
function buildWorld(){
  scene=new THREE.Scene();
  // GTA V uses denser atmospheric fog with a slightly warm tint
  scene.fog=new THREE.FogExp2(0x0a0e1a,.011);

  // ── GTA V-style lighting ──────────────────────────────────
  // Warm golden sun (GTA V's signature warm directional)
  const amb=new THREE.AmbientLight(0x1a2844,.55);scene.add(amb);
  const sun=new THREE.DirectionalLight(0xffe0a0,3.2);
  sun.position.set(80,90,60);sun.castShadow=cfg.shadows;
  sun.shadow.mapSize.width=sun.shadow.mapSize.height=2048;
  sun.shadow.camera.near=1;sun.shadow.camera.far=350;
  sun.shadow.camera.left=sun.shadow.camera.bottom=-90;
  sun.shadow.camera.right=sun.shadow.camera.top=90;
  sun.shadow.bias=-.0004;scene.add(sun);
  // Cool blue fill (sky bounce light — GTA V's characteristic contrast)
  const fill=new THREE.DirectionalLight(0x4488cc,.55);fill.position.set(-60,20,-40);scene.add(fill);
  // Warm back rim from horizon
  const rim=new THREE.DirectionalLight(0xff9944,.22);rim.position.set(0,-8,80);scene.add(rim);
  // Subtle ground bounce (warm)
  const bounce=new THREE.HemisphereLight(0x3a4a5a,0x2a1808,.38);scene.add(bounce);

  // ── Ground (slightly metallic for wet-road reflection) ───
  const gm=new THREE.Mesh(
    new THREE.PlaneGeometry(220,220,24,24),
    new THREE.MeshStandardMaterial({color:0x131820,roughness:.78,metalness:.22})
  );
  gm.rotation.x=-Math.PI/2;gm.receiveShadow=true;scene.add(gm);collidables.push(gm);
  scene.add(new THREE.GridHelper(220,44,0x1e2d40,0x0d161f));

  // Cover objects [x,y,z, w,h,d, hex] — slightly higher roughness/metalness for PBR look
  const cov=[
    [10,1,-14,4,2,1.5,0x232b3a],[-12,1.5,-20,3,3,1.5,0x2a3048],
    [0,2.5,-30,7,5,2,0x222838],[-8,1,-36,4,2,4,0x252e3c],
    [20,3,-26,2,6,2,0x2e2e42],[-20,1.5,-12,9,3,1,0x232338],
    [5,1,-43,5,2,5,0x272740],[-5,4,-52,3,8,3,0x2b334e],
    [30,1,-41,1.5,2,8,0x282e3c],[-30,2,-46,4,4,2,0x222838],
    [15,1,-56,11,2,1.5,0x2e2e42],[-15,2.5,-62,2,5,2,0x262636],
    [0,1.5,-66,8,3,3,0x2a3048],[40,1,-20,3,2,13,0x232338],
    [-40,3,-30,4,6,4,0x2a3048],[50,8,-52,9,16,9,0x1c2030],
    [-50,10,-57,11,20,11,0x181c28],[44,5,-14,6,10,6,0x222030],
    [-44,6,-10,5,12,5,0x1c2030],[8,.5,-19,3,1,3,0x262e40],
    [-6,.75,-23,4,1.5,4,0x283048],[0,.5,-8,6,1,2,0x232838],
    [12,2,-48,5,4,2,0x242a38],[-18,1,-52,6,2,6,0x1e2432],
    [35,2.5,-62,4,5,4,0x22283a],[-35,1.5,-18,7,3,2,0x262e3c],
  ];
  cov.forEach(([x,y,z,w,h,d,c])=>{
    const m=new THREE.Mesh(
      new THREE.BoxGeometry(w,h,d),
      new THREE.MeshStandardMaterial({color:c,roughness:.72,metalness:.28})
    );
    m.position.set(x,y,z);m.castShadow=true;m.receiveShadow=true;
    scene.add(m);collidables.push(m);
  });

  // Enemies
  for(let i=0;i<10;i++){
    const a=(i/10)*Math.PI*2,r=18+Math.random()*22;
    addEnemy(Math.cos(a)*r,1.1,Math.sin(a)*r-28);
  }

  // ── Atmospheric Sky (Rayleigh + Mie scattering, GTA V style) ──
  const sky=new THREE.Mesh(
    new THREE.SphereGeometry(450,32,16),
    new THREE.ShaderMaterial({
      uniforms:{sunDir:{value:new THREE.Vector3(80,90,60).normalize()}},
      vertexShader:`varying vec3 vPos;void main(){vPos=position;gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.);}`,
      fragmentShader:`
        uniform vec3 sunDir;varying vec3 vPos;
        void main(){
          vec3 dir=normalize(vPos);
          float t=clamp(dir.y*.5+.5,0.,1.);
          // Rayleigh sky gradient (deep navy to warm horizon)
          vec3 zenith=vec3(.04,.06,.14);
          vec3 horizon=vec3(.18,.24,.38);
          vec3 sky=mix(horizon,zenith,pow(t,.55));
          // Mie scattering haze (warm near sun)
          float sun=max(0.,dot(dir,sunDir));
          float mie=pow(sun,5.)*.28;
          sky+=vec3(.9,.55,.2)*mie;
          // Sun disk
          float disk=pow(sun,380.)*.95;
          sky+=vec3(1.,.92,.72)*disk;
          // Horizon glow
          float glow=pow(max(0.,1.-abs(dir.y)*4.),2.)*.22;
          sky+=vec3(.95,.6,.2)*glow;
          gl_FragColor=vec4(sky,1.);
        }`,
      side:THREE.BackSide
    })
  );
  scene.add(sky);

  // Muzzle flash
  muzzleMesh=new THREE.Mesh(
    new THREE.PlaneGeometry(.42,.42),
    new THREE.MeshBasicMaterial({color:0xffaa00,transparent:true,opacity:0,depthWrite:false})
  );
  scene.add(muzzleMesh);
}

function addEnemy(x,y,z){
  const mat=new THREE.MeshStandardMaterial({color:0x1a0000,emissive:0xff1133,emissiveIntensity:.42,roughness:.5});
  const body=new THREE.Mesh(new THREE.BoxGeometry(.78,1.8,.58),mat);
  body.position.set(x,y,z);body.castShadow=true;
  body.userData={isEnemy:true,hp:100,phase:Math.random()*Math.PI*2};
  const pl=new THREE.PointLight(0xff1133,.65,3.5);body.add(pl);
  scene.add(body);enemies.push(body);collidables.push(body);
}

// ── Player Init ──────────────────────────────────────────
function initPlayer(){
  player=new Player(collidables);player.pos.set(0,0,6);
  const grp=new THREE.Group();
  const body=new THREE.Mesh(new THREE.CylinderGeometry(.34,.34,1.4,8),new THREE.MeshStandardMaterial({color:0x2c3d52,roughness:.7}));
  body.castShadow=true;
  const head=new THREE.Mesh(new THREE.SphereGeometry(.24,10,8),new THREE.MeshStandardMaterial({color:0x3d5068,roughness:.6}));
  head.position.y=.86;body.add(head);
  const gun=new THREE.Mesh(new THREE.BoxGeometry(.09,.11,.58),new THREE.MeshStandardMaterial({color:0x1a1a28,roughness:.35,metalness:.85}));
  gun.position.set(.26,.28,-.38);body.add(gun);
  grp.add(body);grp.position.copy(player.pos);scene.add(grp);
  player.setMesh(grp);
  player.onLand=(v)=>{if(v>2.8)camCtrl.land(v)};
}

// ── Three.js Setup ───────────────────────────────────────
function initThree(){
  const cv=document.getElementById('gc');
  cam=new THREE.PerspectiveCamera(cfg.fov,window.innerWidth/window.innerHeight,.1,800);
  ren=new THREE.WebGLRenderer({canvas:cv,antialias:cfg.shadows,powerPreference:'high-performance'});
  ren.setSize(window.innerWidth,window.innerHeight);
  ren.setPixelRatio(Math.min(window.devicePixelRatio,2));
  ren.shadowMap.enabled=cfg.shadows;ren.shadowMap.type=THREE.PCFSoftShadowMap;
  // Disable Three.js built-in tonemapping — RageFX handles it via Uncharted 2 operator
  ren.toneMapping=THREE.NoToneMapping;
  // Keep linear encoding — RageFX composite shader applies gamma correction itself
  try{ren.outputEncoding=THREE.LinearEncoding}catch(e){}
  clock=new THREE.Clock();
  buildWorld();initPlayer();
  camCtrl=new CamCtrl(cam,collidables);
  camCtrl.armSp.snap(player.pos.x,player.pos.y,player.pos.z);
  mmCtx=document.getElementById('mmc').getContext('2d');
  // Init RAGE post-processing system
  try{rageFX=new RageFX(ren,window.innerWidth,window.innerHeight)}catch(e){console.warn('RageFX init failed, falling back:',e);rageFX=null;}
  window.addEventListener('resize',()=>{
    const w=window.innerWidth,h=window.innerHeight;
    cam.aspect=w/h;cam.updateProjectionMatrix();
    ren.setSize(w,h);
    if(rageFX)rageFX.resize(w,h);
  });
}

// ── Item Bar ─────────────────────────────────────────────
function buildBar(){
  const el=document.getElementById('ib');el.innerHTML='';
  ws.wpns.forEach((w,i)=>{
    const s=document.createElement('div');
    s.className=`is ${w.rar} ${i===ws.slot?'sel':''}`;s.id=`s${i}`;
    s.innerHTML=`<div class="isn">${i+1}</div><div class="isi">${w.icon}</div><div class="isa">${w.ammo}</div><div class="irb"></div>`;
    s.onclick=()=>wSel(i);
    el.appendChild(s);
    // Staggered entrance
    s.style.cssText='opacity:0;transform:translateY(36px)';
    setTimeout(()=>{s.style.transition='all .5s cubic-bezier(.34,1.56,.64,1)';s.style.cssText=''},90+i*55);
  });
}
function updBar(){
  ws.wpns.forEach((w,i)=>{
    const s=document.getElementById(`s${i}`);if(!s)return;
    s.classList.toggle('sel',i===ws.slot);
    s.querySelector('.isa').textContent=w.ammo;
  });
  const w=ws.wpns[ws.slot];
  document.getElementById('am').textContent=w.ammo;
  document.getElementById('ar').textContent='/ '+w.rsv;
}

// ── HUD helpers ──────────────────────────────────────────
let wnTimer;
function showWpnName(n){
  const el=document.getElementById('wn');
  el.classList.remove('on');void el.offsetWidth;el.textContent=n;el.classList.add('on');
  clearTimeout(wnTimer);wnTimer=setTimeout(()=>el.classList.remove('on'),2400);
}
function showHit(){
  const h=document.getElementById('hmk');h.classList.remove('on');void h.offsetWidth;h.classList.add('on');
}
function showKillBanner(){
  const b=document.getElementById('kb');b.classList.remove('on');void b.offsetWidth;b.classList.add('on');
}
function notify(txt){
  const el=document.createElement('div');el.className='nf';el.textContent=txt;
  document.getElementById('nw').appendChild(el);
  setTimeout(()=>el.remove(),3000);
}
function updMinimap(){
  const ctx=mmCtx,sz=130,sc=3.2,cx=sz/2,cy=sz/2;
  ctx.clearRect(0,0,sz,sz);
  ctx.fillStyle='rgba(0,0,0,.82)';ctx.beginPath();ctx.arc(cx,cy,sz/2,0,Math.PI*2);ctx.fill();
  // grid lines
  ctx.strokeStyle='rgba(0,212,255,.06)';ctx.lineWidth=.5;
  for(let i=-sz;i<sz;i+=12){
    const xi=cx+(i-(player.pos.x%12)*sc);if(xi>0&&xi<sz){ctx.beginPath();ctx.moveTo(xi,0);ctx.lineTo(xi,sz);ctx.stroke()}
    const yi=cy+(i-(player.pos.z%12)*sc);if(yi>0&&yi<sz){ctx.beginPath();ctx.moveTo(0,yi);ctx.lineTo(sz,yi);ctx.stroke()}
  }
  // objects
  collidables.forEach(o=>{
    if(!o.geometry||o===player.mesh)return;
    const rx=(o.position.x-player.pos.x)*sc+cx,rz=(o.position.z-player.pos.z)*sc+cy;
    if(rx<4||rx>sz-4||rz<4||rz>sz-4)return;
    ctx.fillStyle=o.userData.isEnemy?'#ff2244':'#2a3d55';ctx.fillRect(rx-2,rz-2,4,4);
  });
  // player arrow
  ctx.save();ctx.translate(cx,cy);ctx.rotate(-camCtrl.yawSp.val);
  ctx.fillStyle='#00d4ff';ctx.beginPath();ctx.moveTo(0,-7);ctx.lineTo(5,6);ctx.lineTo(-5,6);ctx.closePath();
  ctx.shadowColor='#00d4ff';ctx.shadowBlur=7;ctx.fill();ctx.restore();
  ctx.strokeStyle='rgba(0,212,255,.18)';ctx.lineWidth=1;ctx.beginPath();ctx.arc(cx,cy,sz/2-1,0,Math.PI*2);ctx.stroke();
}

// ── Settings UI ──────────────────────────────────────────
function stab(id,el){
  document.querySelectorAll('.stab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.ss').forEach(s=>s.classList.remove('on'));
  el.classList.add('on');document.getElementById('tab-'+id).classList.add('on');
}
function setQ(v,b){b.closest('.qo').querySelectorAll('.qb').forEach(x=>x.classList.remove('on'));b.classList.add('on');
  const pr={low:.5,med:.75,high:1,ultra:1.5};ren&&ren.setPixelRatio(Math.min(window.devicePixelRatio,pr[v]*2));
  ren&&(ren.shadowMap.enabled=v!=='low');
}
function setQ2(v,b){b.closest('.qo').querySelectorAll('.qb').forEach(x=>x.classList.remove('on'));b.classList.add('on')}
function tog(k){
  const el=document.getElementById('tg-'+k);if(!el)return;
  el.classList.toggle('on');const on=el.classList.contains('on');
  if(k==='shad')cfg.shadows=on,ren&&(ren.shadowMap.enabled=on);
  if(k==='sway')cfg.sway=on;
  if(k==='iy')cfg.invertY=on;
}
function openSettings(){document.getElementById('sp').classList.add('on')}
function closeSettings(){document.getElementById('sp').classList.remove('on')}

// ── Game State ───────────────────────────────────────────
let gState='loading';

function startGame(){
  const mm=document.getElementById('mm');
  mm.style.transition='opacity .5s ease,transform .5s ease';
  mm.style.opacity='0';mm.style.transform='scale(1.06)';
  setTimeout(()=>{
    mm.style.display='none';
    const cv=document.getElementById('gc');cv.style.display='block';
    document.getElementById('hud').classList.add('on');
    document.getElementById('ib').classList.add('on');
    gState='playing';buildBar();
    // stagger HUD elements in
    ['.hw','.aw','.mm2','.lb2'].forEach((sel,i)=>{
      const el=document.querySelector(sel);if(!el)return;
      el.style.cssText='opacity:0;transform:translateY(16px)';
      setTimeout(()=>{el.style.transition='all .6s cubic-bezier(.16,1,.3,1)';el.style.cssText=''},180+i*90);
    });
    showWpnName(ws.wpns[ws.slot].name);
    notify('◆ DEPLOYED — WATCH YOUR SIX');
    if(IS_MOBILE){
      // Mobile: no pointer lock needed, show virtual controls
      document.getElementById('mob-ctrl').style.display='block';
      // Prevent page scroll/zoom during gameplay
      document.body.style.overflow='hidden';
      document.body.style.touchAction='none';
    } else {
      reqLock();
    }
  },480);
}

function promptLeave(){
  document.exitPointerLock();
  document.getElementById('lc').classList.add('on');
}
function cancelLeave(){
  document.getElementById('lc').classList.remove('on');
  if(gState==='playing')reqLock();
}
function doLeave(){
  document.getElementById('lc').classList.remove('on');
  document.getElementById('hud').classList.remove('on');
  document.getElementById('ib').classList.remove('on');
  document.getElementById('gc').style.display='none';
  gState='menu';
  const mm=document.getElementById('mm');
  mm.style.display='flex';mm.style.opacity='0';mm.style.transform='scale(.96)';
  requestAnimationFrame(()=>{
    mm.style.transition='all .5s cubic-bezier(.16,1,.3,1)';
    mm.style.opacity='1';mm.style.transform='scale(1)';
  });
  player.pos.set(0,0,6);player.vel.set(0,0,0);
  camCtrl.armSp.snap(0,0,6);camCtrl.yawSp.snap(0);camCtrl.pitchSp.snap(-.14);
  camCtrl.tgtYaw=0;camCtrl.tgtPitch=-.14;
}
function quitMenu(){
  const mm=document.getElementById('mm');
  mm.style.transition='opacity .4s,transform .4s';mm.style.opacity='0';mm.style.transform='scale(.94)';
  setTimeout(()=>{mm.innerHTML='<div style="font-family:var(--font-d);font-size:11px;letter-spacing:.5em;color:rgba(0,212,255,.3)">GOODBYE, SOLDIER</div>'},400);
}

// ── Main Loop ────────────────────────────────────────────
function loop(){
  requestAnimationFrame(loop);
  const dt=Math.min(clock.getDelta(),.05);
  if(gState!=='playing'){
    if(rageFX)rageFX.render(scene,cam,dt);
    else if(ren)ren.render(scene,cam);
    return
  }

  // Poll gamepad + mobile BEFORE consuming input so they can inject into K/MB
  GP.poll(dt);
  if(mobileCtrl)mobileCtrl.poll();

  const inp=consumeInput();
  if(locked||IS_MOBILE){camCtrl.applyMouse(inp.dx,inp.dy)}
  const arrowSpeed=2.2;
  if(K.ArrowLeft) camCtrl.tgtYaw+=arrowSpeed*dt;
  if(K.ArrowRight)camCtrl.tgtYaw-=arrowSpeed*dt;
  if(inp.sc)wScroll(inp.sc);
  for(let i=0;i<6;i++)if(K[`Digit${i+1}`])wSel(i);
  if(K.KeyR)wReload();

  const ads=MB[2];camCtrl.setADS(ads);

  // Fire: mouse left-click OR controller RT (injected into _gpFire by GP.poll)
  if(GP._gpFire||MB[0])wFire();
  GP._gpFire=false;

  player.update(dt);
  camCtrl.setSprint(player.sprt);
  camCtrl.update(dt,player.pos,player.vel,player.grnd);

  // UI sync
  document.getElementById('si2').classList.toggle('on',player.sprt);
  document.getElementById('sv2').classList.toggle('on',player.sprt);
  document.getElementById('mprompt').classList.toggle('on',player.canMnt);

  // Muzzle flash
  if(muzzleTimer>0){
    muzzleTimer-=dt;
    const t=muzzleTimer/.055;muzzleMesh.material.opacity=t*.85;
    const qy=new THREE.Quaternion().setFromAxisAngle(new THREE.Vector3(0,1,0),camCtrl.yawSp.val);
    const off=new THREE.Vector3(.28,1.38,-.95).applyQuaternion(qy);
    muzzleMesh.position.copy(player.pos).add(off);muzzleMesh.lookAt(cam.position);
  } else muzzleMesh.material.opacity=0;

  // Enemy bob
  const t=Date.now()*.002;
  enemies.forEach(e=>{
    e.position.y=1.1+Math.sin(t+e.userData.phase)*.065;
    e.rotation.y+=dt*.28;
  });

  updMinimap();
  // Route through RAGE post-processing pipeline
  if(rageFX)rageFX.render(scene,cam,dt);
  else ren.render(scene,cam);
}

// ── Canvas click to re-lock (desktop only) ───────────────
document.getElementById('gc').addEventListener('click',()=>{
  if(gState==='playing'&&!locked&&!IS_MOBILE)reqLock();
});

// ── Boot ─────────────────────────────────────────────────
initThree();
mobileCtrl=new MobileCtrl();
setTimeout(()=>{
  const ls=document.getElementById('ls');
  ls.style.transition='opacity .6s ease';ls.style.opacity='0';
  setTimeout(()=>{
    ls.style.display='none';
    const mm=document.getElementById('mm');
    mm.style.display='flex';
    if(IS_MOBILE)notify('📱 Touch controls active');
  },600);
},2000);
loop();
</script>

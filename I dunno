<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script>
'use strict';
// ══════════════════════════════════════════════════════════
//   APEX PROTOCOL — TPS ENGINE
//   Spring Camera Physics · Mantling · Fortnite Item Bar
// ══════════════════════════════════════════════════════════

// ── Config ──────────────────────────────────────────────
const cfg = {
  fov:78, draw:400, sens:6, adsMult:.6,
  springK:190, // camera spring stiffness (drag catch-up feel)
  sway:true, invertY:false, shadows:true
};

// ── Spring Physics ───────────────────────────────────────
// Critical-damped spring: F = -k*x - d*v
// This is the secret sauce — gives the "drag catch-up" easing
class Sp {
  constructor(k=190,d=26,m=1){this.k=k;this.d=d;this.m=m;this.v=0;this.val=0;this.tgt=0}
  tick(dt){
    const f=-this.k*(this.val-this.tgt)-this.d*this.v;
    this.v+=(f/this.m)*dt;this.val+=this.v*dt;return this.val
  }
  snap(v){this.val=v;this.tgt=v;this.v=0}
}
class Sp3{
  constructor(k=190,d=26){this.x=new Sp(k,d);this.y=new Sp(k,d);this.z=new Sp(k,d)}
  tgt(x,y,z){this.x.tgt=x;this.y.tgt=y;this.z.tgt=z}
  tick(dt){return{x:this.x.tick(dt),y:this.y.tick(dt),z:this.z.tick(dt)}}
  snap(x,y,z){this.x.snap(x);this.y.snap(y);this.z.snap(z)}
}

// ── Input ───────────────────────────────────────────────
const K={}, MB=[0,0,0];
let mdx=0,mdy=0,scroll=0,locked=false;
document.addEventListener('keydown',e=>{K[e.code]=1;if(locked&&['Space','Tab','ArrowLeft','ArrowRight','ArrowUp','ArrowDown'].includes(e.code))e.preventDefault()});
document.addEventListener('keyup',e=>{K[e.code]=0});
document.addEventListener('mousedown',e=>{MB[e.button]=1});
document.addEventListener('mouseup',e=>{MB[e.button]=0});
document.addEventListener('mousemove',e=>{if(locked){mdx+=e.movementX;mdy+=e.movementY}});
document.addEventListener('wheel',e=>{if(locked)scroll+=e.deltaY},{passive:true});
document.addEventListener('pointerlockchange',()=>{locked=document.pointerLockElement===document.getElementById('gc')});
function consumeInput(){const r={dx:mdx,dy:mdy,sc:scroll};mdx=mdy=scroll=0;return r}
function reqLock(){document.getElementById('gc').requestPointerLock()}

// ── Device Detection ────────────────────────────────────
const IS_MOBILE=('ontouchstart' in window)||navigator.maxTouchPoints>0||/Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
if(IS_MOBILE){document.body.classList.add('mobile')}

// ── Gamepad — Fortnite Combat Pro layout ────────────────
// Fortnite Combat Pro (most popular competitive preset):
//   Left  stick (0/1) = Move
//   Right stick (2/3) = Look (dual-zone exponential curve)
//   RT/R2  (btn 7)    = Fire
//   LT/L2  (btn 6)    = ADS
//   A/Cross (btn 0)   = Jump
//   B/Circle (btn 1)  = Crouch
//   X/Square (btn 2)  = Reload / Interact
//   Y/Tri    (btn 3)  = Mantle (our closest equivalent)
//   RB/R1   (btn 5)   = Next weapon
//   LB/L1   (btn 4)   = Previous weapon
//   L3/LS   (btn 10)  = Sprint toggle (+ auto-sprint at full deflection)
//   R3/RS   (btn 11)  = Crouch (alt binding, common in Combat Pro)
//   D-up    (btn 12)  = Slot 1
//   D-right (btn 15)  = Next weapon
//   D-left  (btn 14)  = Prev weapon
//   Options (btn 9)   = Menu / Leave
const GP={
  // Fortnite dual-zone look curve:
  // inner linear zone → outer exponential boost (the "Fortnite feel")
  _inner:.10,   // inner deadzone
  _linear:.50,  // linear→boost threshold
  _boost:3.2,   // boost multiplier beyond threshold
  baseSens:2.6, // base look speed (rad/s)
  _prevBtn:[],
  _wpnCd:0,
  _gpFire:false,
  _autoSprintMag:.82, // left-stick magnitude for auto-sprint (like Fortnite)

  // Fortnite dual-zone exponential look curve
  _curve(v){
    const a=Math.abs(v);
    if(a<this._inner)return 0;
    const norm=(a-this._inner)/(1-this._inner);
    let out;
    if(norm<this._linear){
      out=norm*(1/this._linear)*.38; // linear zone (slow precise aim)
    } else {
      const t=(norm-this._linear)/(1-this._linear);
      out=.38+t*t*t*.62;            // cubic ramp in boost zone
    }
    return Math.sign(v)*out*this._baseSens;
  },

  poll(dt){
    let pads=[];try{pads=navigator.getGamepads?navigator.getGamepads():[]}catch(e){return}
    let gp=null;
    for(const p of pads){if(p&&p.connected){gp=p;break}}
    if(!gp)return;

    const ax=(i)=>gp.axes[i]||0;
    const btn=(i)=>!!(gp.buttons[i]&&gp.buttons[i].pressed);
    const btnVal=(i)=>gp.buttons[i]?gp.buttons[i].value:0;
    const justPressed=(i)=>btn(i)&&!this._prevBtn[i];

    // ── Left stick → move ──────────────────────────────
    const lx=ax(0),ly=ax(1);
    const lmag=Math.hypot(lx,ly);
    // Radial deadzone (Fortnite uses this, feels cleaner than per-axis)
    const ld=.12;
    const lfx=lmag>ld?lx*(lmag-ld)/(lmag*(1-ld)):0;
    const lfy=lmag>ld?ly*(lmag-ld)/(lmag*(1-ld)):0;
    K['KeyW']=K['KeyW']||(lfy<-.18?1:0);
    K['KeyS']=K['KeyS']||(lfy>.18?1:0);
    K['KeyA']=K['KeyA']||(lfx<-.18?1:0);
    K['KeyD']=K['KeyD']||(lfx>.18?1:0);

    // Auto-sprint: full left-stick push forward = sprint (Fortnite "Sprint by Default" feel)
    if(lmag>this._autoSprintMag&&lfy<-.2)K['ShiftLeft']=1;

    // ── Right stick → look (Fortnite dual-zone curve) ──
    const rx=ax(2),ry=ax(3);
    if(gState==='playing'){
      camCtrl.tgtYaw  -=this._curve(rx)*dt;
      const iy=cfg.invertY?1:-1;
      camCtrl.tgtPitch +=this._curve(ry)*dt*.72*iy;
      camCtrl.tgtPitch  =Math.max(-1.08,Math.min(.65,camCtrl.tgtPitch));
    }

    // ── RT/R2 = Fire ───────────────────────────────────
    if(btnVal(7)>.4)this._gpFire=true;

    // ── LT/L2 = ADS ────────────────────────────────────
    MB[2]=btnVal(6)>.4?1:0;

    // ── Face buttons ───────────────────────────────────
    // A/Cross = Jump
    K['Space']=K['Space']||(btn(0)?1:0);
    // B/Circle = Crouch
    K['ControlLeft']=K['ControlLeft']||(btn(1)?1:0);
    // X/Square = Reload (justPressed for single trigger)
    if(justPressed(2))K['KeyR']=1;
    // Y/Triangle = Mantle
    K['KeyF']=K['KeyF']||(btn(3)?1:0);

    // ── Shoulders = weapon cycle ────────────────────────
    this._wpnCd-=dt;
    if(this._wpnCd<=0){
      if(justPressed(5)||justPressed(15)){wScroll(1);this._wpnCd=.18}
      if(justPressed(4)||justPressed(14)){wScroll(-1);this._wpnCd=.18}
    }

    // ── D-pad slots (Fortnite quick-select) ─────────────
    if(justPressed(12))wSel(0); // D-up = slot 1
    if(justPressed(13))wSel(1); // D-down = slot 2

    // ── Stick clicks ────────────────────────────────────
    // L3 = sprint toggle
    K['ShiftLeft']=K['ShiftLeft']||(btn(10)?1:0);
    // R3 = crouch (alt Combat Pro binding)
    if(justPressed(11))K['ControlLeft']=1;

    // ── Options/Start = leave ───────────────────────────
    if(justPressed(9)&&gState==='playing')promptLeave();

    this._prevBtn=gp.buttons.map(b=>b.pressed);
  }
};

window.addEventListener('gamepadconnected',e=>{if(typeof notify==='function')notify('🎮 CONTROLLER — COMBAT PRO')});
window.addEventListener('gamepaddisconnected',()=>{if(typeof notify==='function')notify('⚠ CONTROLLER DISCONNECTED')});

// ── Mobile Controls ─────────────────────────────────────
// Architecture mirrors Fortnite mobile:
//   Left 40% screen  → floating virtual joystick
//   Right 60% screen → drag-to-look, tap fires nothing (fire btn handles it)
//   Action buttons   → inject into K/MB like keyboard/controller
class MobileCtrl{
  constructor(){
    this.lx=0;this.ly=0;       // normalised joystick output [-1,1]
    this._stickId=null;        // active touch id for joystick
    this._lookId=null;         // active touch id for look drag
    this._lookLastX=0;this._lookLastY=0;
    this._fire=false;
    this._enabled=false;
    if(!IS_MOBILE)return;
    this._enabled=true;
    this._stickZone=document.getElementById('mob-stick-zone');
    this._knob=document.getElementById('mob-knob');
    this._lookZone=document.getElementById('mob-look');
    this._R=this._stickZone.offsetWidth/2||75; // outer radius
    this._setupJoystick();
    this._setupLook();
    this._setupButtons();
  }

  _setupJoystick(){
    const sz=this._stickZone,r=this._R;
    sz.addEventListener('touchstart',e=>{
      e.preventDefault();
      const t=e.changedTouches[0];
      if(this._stickId!==null)return;
      this._stickId=t.identifier;
      this._moveKnob(t,sz,r);
    },{passive:false});
    document.addEventListener('touchmove',e=>{
      if(this._stickId===null)return;
      for(const t of e.changedTouches){
        if(t.identifier===this._stickId){
          e.preventDefault();
          this._moveKnob(t,sz,r);
          break;
        }
      }
    },{passive:false});
    document.addEventListener('touchend',e=>{
      for(const t of e.changedTouches){
        if(t.identifier===this._stickId){
          this._stickId=null;this.lx=0;this.ly=0;
          this._knob.style.left='50%';this._knob.style.top='50%';
          break;
        }
      }
    });
  }

  _moveKnob(touch,sz,r){
    const rect=sz.getBoundingClientRect();
    const cx=rect.left+r,cy=rect.top+r;
    let dx=touch.clientX-cx,dy=touch.clientY-cy;
    const dist=Math.hypot(dx,dy);
    if(dist>r){dx*=r/dist;dy*=r/dist;}
    this._knob.style.left=(r+dx)+'px';
    this._knob.style.top =(r+dy)+'px';
    // Apply radial deadzone to output
    const dmag=Math.hypot(dx,dy)/r;
    const dead=.14;
    const norm=dmag>dead?(dmag-dead)/(1-dead):0;
    const scale=dmag>0?norm/dmag:0;
    this.lx=dx/r*scale;
    this.ly=dy/r*scale;
  }

  _setupLook(){
    const lz=this._lookZone;
    lz.addEventListener('touchstart',e=>{
      e.preventDefault();
      const t=e.changedTouches[0];
      if(this._lookId!==null)return;
      this._lookId=t.identifier;
      this._lookLastX=t.clientX;this._lookLastY=t.clientY;
    },{passive:false});
    lz.addEventListener('touchmove',e=>{
      e.preventDefault();
      for(const t of e.changedTouches){
        if(t.identifier===this._lookId){
          const dx=t.clientX-this._lookLastX;
          const dy=t.clientY-this._lookLastY;
          // Inject into the global mouse delta (same as mousemove)
          mdx+=dx*1.8;mdy+=dy*1.8;
          this._lookLastX=t.clientX;this._lookLastY=t.clientY;
          break;
        }
      }
    },{passive:false});
    lz.addEventListener('touchend',e=>{
      for(const t of e.changedTouches){
        if(t.identifier===this._lookId){this._lookId=null;break}
      }
    });
  }

  _setupButtons(){
    const bind=(id,down,up)=>{
      const el=document.getElementById(id);if(!el)return;
      el.addEventListener('touchstart',e=>{e.preventDefault();down&&down();},{passive:false});
      el.addEventListener('touchend',e=>{e.preventDefault();up&&up();},{passive:false});
    };
    bind('mob-fire',
      ()=>{MB[0]=1},
      ()=>{MB[0]=0}
    );
    bind('mob-jump',
      ()=>{K['Space']=1},
      ()=>{K['Space']=0}
    );
    bind('mob-ads',
      ()=>{MB[2]=1},
      ()=>{MB[2]=0}
    );
    bind('mob-reload',
      ()=>{wReload()},null
    );
    bind('mob-crouch',
      ()=>{K['ControlLeft']=1},
      ()=>{K['ControlLeft']=0}
    );
  }

  // Called every frame from the game loop — injects stick into K
  poll(){
    if(!this._enabled)return;
    const th=.18;
    K['KeyW']=K['KeyW']||(this.ly<-th?1:0);
    K['KeyS']=K['KeyS']||(this.ly>th?1:0);
    K['KeyA']=K['KeyA']||(this.lx<-th?1:0);
    K['KeyD']=K['KeyD']||(this.lx>th?1:0);
    // Auto-sprint at full stick (Fortnite mobile auto-sprints)
    if(Math.hypot(this.lx,this.ly)>.78&&this.ly<-th)K['ShiftLeft']=1;
  }
}
let mobileCtrl=null;

// ══════════════════════════════════════════════════════════
//   RAGE-INSPIRED POST-PROCESSING PIPELINE
//   Based on GTA V Graphics Study (Adrian Courrèges, 2015)
//   and RAGE 7/8 rendering architecture research:
//
//   Pass 1 → Main scene to HDR buffer (+ depth texture)
//   Pass 2 → Bright pass (soft knee threshold)
//   Pass 3 → Bloom: 4-stage dual separable Gaussian blur
//   Pass 4 → SSAO: hemisphere depth-diff ambient occlusion
//   Pass 5 → SSAO blur (smooth the noise)
//   Pass 6 → God Rays: radial blur from sun screen position
//   Pass 7 → Composite:
//              • Uncharted 2 filmic tonemap (GTA V exact operator)
//              • GTA V color grade (warm shadows / cool highlights)
//              • Subtle Depth of Field
//              • Chromatic Aberration (lens fringing)
//              • Film Grain
//              • Vignette
// ══════════════════════════════════════════════════════════

const VS_QUAD=`varying vec2 vUv;void main(){vUv=uv;gl_Position=vec4(position,1.);}`;

const FS_BRIGHT=`
uniform sampler2D tDiffuse;uniform float threshold;varying vec2 vUv;
void main(){
  vec3 c=texture2D(tDiffuse,vUv).rgb;
  float lum=dot(c,vec3(0.2126,0.7152,0.0722));
  float knee=threshold*.5;
  float rq=clamp(lum-threshold+knee,0.,2.*knee);
  rq=(rq*rq)/(4.*knee+1e-5);
  float w=max(rq,lum-threshold)/max(lum,1e-5);
  gl_FragColor=vec4(c*w,1.);
}`;

const FS_BLUR=`
uniform sampler2D tDiffuse;uniform vec2 resolution;uniform vec2 direction;varying vec2 vUv;
void main(){
  vec2 t=direction/resolution;vec4 c=vec4(0.);
  c+=texture2D(tDiffuse,vUv-t*4.)*.0162;
  c+=texture2D(tDiffuse,vUv-t*3.)*.054;
  c+=texture2D(tDiffuse,vUv-t*2.)*.1216;
  c+=texture2D(tDiffuse,vUv-t   )*.1945;
  c+=texture2D(tDiffuse,vUv     )*.2270;
  c+=texture2D(tDiffuse,vUv+t   )*.1945;
  c+=texture2D(tDiffuse,vUv+t*2.)*.1216;
  c+=texture2D(tDiffuse,vUv+t*3.)*.054;
  c+=texture2D(tDiffuse,vUv+t*4.)*.0162;
  gl_FragColor=c;
}`;

const FS_SSAO=`
precision highp float;
uniform sampler2D tDepth;uniform vec2 resolution;uniform float time;varying vec2 vUv;
float linearize(float d){float n=.1,f=800.;return n*f/(f-d*(f-n));}
float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
void main(){
  float depth=texture2D(tDepth,vUv).r;
  if(depth>=.9999){gl_FragColor=vec4(1.);return;}
  float linD=linearize(depth);
  float texel=1./max(resolution.x,resolution.y);
  float sr=clamp(20./linD,3.,22.)*texel;
  float angle=hash(floor(vUv*resolution)+floor(time)*17.)*6.2832;
  float ao=0.;
  for(int i=0;i<16;i++){
    float fi=float(i)/16.;
    float r=sqrt(fi+.01)*sr;
    float theta=float(i)*2.39996+angle;
    vec2 off=vec2(cos(theta),sin(theta))*r;
    off.x*=resolution.y/resolution.x;
    float sd=linearize(texture2D(tDepth,clamp(vUv+off,vec2(0.),vec2(1.))).r);
    float diff=linD-sd;
    float rc=smoothstep(0.,1.,sr*resolution.x/max(abs(diff),.01));
    ao+=(diff>.09?1.:0.)*rc;
  }
  ao=1.-ao/16.*.88;
  gl_FragColor=vec4(vec3(ao),1.);
}`;

const FS_GODRAY=`
uniform sampler2D tDiffuse;uniform vec2 sunPos;
uniform float exposure,decay,density,weight;varying vec2 vUv;
void main(){
  vec2 tc=vUv;
  vec2 delta=(tc-sunPos)*(1./64.*density);
  float dc=1.;vec3 color=vec3(0.);
  for(int i=0;i<64;i++){
    tc-=delta;
    vec3 s=texture2D(tDiffuse,clamp(tc,0.,1.)).rgb;
    float lum=dot(s,vec3(0.2126,0.7152,0.0722));
    s*=step(.52,lum);
    color+=s*dc*weight;dc*=decay;
  }
  color*=exposure;
  float d=length(vUv-sunPos);
  color*=max(0.,1.-d*1.7);
  gl_FragColor=vec4(color,1.);
}`;

// ══════════════════════════════════════════════════════════
//   RAGE VOLUMETRIC CLOUD ENGINE
//   Architecture based on:
//   • GTA V RAGE: ring mesh + density/normal map (noise16_p, skydome.ytd)
//     scrolled UV textures — horizon band approach
//   • RDR2 RAGE 2018 (Fabian Bauer, SIGGRAPH 2019):
//     voxelization + raymarching, worleynoise_tiling + cloudnoisevolume,
//     Beer-Lambert transmittance, Henyey-Greenstein phase function,
//     sky irradiance probe grid, paraboloid map cloud contribution
//
//   Our WebGL implementation:
//   1. Inverse view-projection ray reconstruction (no mesh needed)
//   2. Altitude slab intersection [y=75, y=210] (GTA V ring band)
//   3. 3D procedural Worley (cellular/voronoi) — replaces worleynoise_tiling
//   4. FBM smooth noise for large-scale coverage — replaces noise16_p
//   5. Combined density = coverage - worley_erosion (RAGE approach)
//   6. Height gradient shaping (thin at edges, thick in middle)
//   7. Beer-Lambert optical depth accumulation
//   8. 6-step light march toward sun for in-scattering
//   9. Henyey-Greenstein forward+back scatter (g=0.65)
//  10. Atmospheric horizon fade + sun color modulation
//  11. Wind animation via UV scroll (GTA V's density map scroll)
//  12. Renders at half-res, upsampled in composite (GTA V perf trick)
// ══════════════════════════════════════════════════════════
const FS_CLOUDS=`
precision highp float;
uniform vec3 camPos,sunDir;
uniform mat4 invViewProj;
uniform float time;
uniform sampler2D tDepth;
uniform vec2 resolution;
varying vec2 vUv;

// ── Constants ──────────────────────────────────────────────
#define CLOUD_MIN   75.0
#define CLOUD_MAX  210.0
#define STEPS       48
#define LIGHT_STEPS  6
#define PI          3.14159265

// ── 3D hash (fast, good distribution) ─────────────────────
vec3 hash3(vec3 p){
  p=vec3(dot(p,vec3(127.1,311.7,74.7)),
         dot(p,vec3(269.5,183.3,246.1)),
         dot(p,vec3(113.5,271.9,124.6)));
  return fract(sin(p)*43758.5453123);
}
float hash1(vec3 p){return fract(sin(dot(p,vec3(127.1,311.7,74.7)))*43758.5453);}

// ── Smooth value noise (trilinear, GTA V coverage base) ───
float sNoise(vec3 p){
  vec3 i=floor(p),f=fract(p);
  f=f*f*(3.-2.*f);
  return mix(
    mix(mix(hash1(i),            hash1(i+vec3(1,0,0)),f.x),
        mix(hash1(i+vec3(0,1,0)),hash1(i+vec3(1,1,0)),f.x),f.y),
    mix(mix(hash1(i+vec3(0,0,1)),hash1(i+vec3(1,0,1)),f.x),
        mix(hash1(i+vec3(0,1,1)),hash1(i+vec3(1,1,1)),f.x),f.y),f.z);
}

// ── Rotation matrix at global scope (GLSL ES 1.0: no mat3 inside function body) ──
mat3 fbmRot=mat3(1.6,1.2,0.,-1.2,1.6,0.,0.,0.,1.);

// ── FBM (5-octave, like RAGE's noise16_p multi-layer) ─────
float fbm(vec3 p){
  float v=0.;float a=.55;
  for(int i=0;i<5;i++){v+=a*sNoise(p);p=fbmRot*p*2.+vec3(1.7,9.2,3.4);a*=.5;}
  return v;
}

// ── Worley (cellular) noise — RAGE worleynoise_tiling ─────
// Returns distance to nearest feature point (inverted = cloud-like)
float worley(vec3 p){
  vec3 i=floor(p);vec3 f=fract(p);float d=1.;
  for(int x=-1;x<=1;x++)for(int y=-1;y<=1;y++)for(int z=-1;z<=1;z++){
    vec3 n=vec3(float(x),float(y),float(z));
    vec3 r=hash3(i+n)+n-f;
    d=min(d,dot(r,r));
  }
  return 1.-sqrt(d);
}

// ── Cloud density (GTA V density map + RAGE Worley erosion) ──
float cloudDensity(vec3 pos,float wt){
  // Normalised height within cloud layer (RAGE height gradient)
  float h=clamp((pos.y-CLOUD_MIN)/(CLOUD_MAX-CLOUD_MIN),0.,1.);
  float hg=smoothstep(0.,.18,h)*smoothstep(1.,.55,h); // thin edges, full middle
  if(hg<.001)return 0.;

  // Wind scroll — GTA V animates density/normal map UVs for wind
  float spd=wt*.0012;
  vec3 windOff=vec3(spd*3.8,0.,spd*1.4);

  // Large-scale coverage via FBM (replaces GTA V noise16_p density map)
  vec3 bp=pos*.0022+windOff;
  float cov=fbm(bp)*1.55-.45;
  cov=clamp(cov,0.,1.);
  if(cov<.001)return 0.;

  // Detail erosion via Worley (replaces RAGE worleynoise_tiling)
  vec3 dp=pos*.014+windOff*2.2;
  float w1=worley(dp);
  float w2=worley(dp*2.1+vec3(3.7,1.8,5.4))*.5;
  float w3=worley(dp*4.3+vec3(7.2,3.1,2.6))*.25;
  float erosion=(w1+w2+w3)/1.75;

  // RAGE density combination: coverage minus erosion detail
  float dens=cov-(.55-erosion*.55);
  return max(0.,dens)*hg;
}

// ── Henyey-Greenstein phase function (RDR2 forward scatter) ──
float hg(float cosA,float g){
  float g2=g*g;
  return(1.-g2)/(4.*PI*pow(1.+g2-2.*g*cosA,1.5));
}

// ── Light march toward sun (Beer-Lambert in-scatter) ──────
float lightMarch(vec3 pos,float stepSz,float wt){
  vec3 lp=pos;float transmit=1.;
  for(int i=0;i<LIGHT_STEPS;i++){
    lp+=sunDir*stepSz*2.2;
    float ld=cloudDensity(lp,wt);
    transmit*=exp(-ld*stepSz*2.2*72.);
  }
  return transmit;
}

// ── Reconstruct world-space ray from UV + inv view-proj ───
vec3 worldRay(vec2 uv){
  vec4 ndc=vec4(uv*2.-1.,1.,1.);
  vec4 w=invViewProj*ndc;
  return normalize(w.xyz/w.w-camPos);
}

void main(){
  // Reconstruct ray
  vec3 rd=worldRay(vUv);

  // Cull: only sky pixels (depth at far plane)
  float depth=texture2D(tDepth,vUv).r;
  if(depth<.9999){gl_FragColor=vec4(0.,0.,0.,1.);return;}

  // Only raymarch upward or at shallow angles into the cloud layer
  if(rd.y<-.08){gl_FragColor=vec4(0.,0.,0.,1.);return;}

  // ── Slab intersection ──────────────────────────────────
  float tMin=0.;
  float tMax=0.;
  if(abs(rd.y)<.001){
    if(camPos.y<CLOUD_MIN||camPos.y>CLOUD_MAX){gl_FragColor=vec4(0.,0.,0.,1.);return;}
    tMin=0.;tMax=8000.;
  } else {
    float t1=(CLOUD_MIN-camPos.y)/rd.y;
    float t2=(CLOUD_MAX-camPos.y)/rd.y;
    tMin=max(0.,min(t1,t2));
    tMax=max(t1,t2);
  }
  if(tMin>tMax||tMax<.0){gl_FragColor=vec4(0.,0.,0.,1.);return;}
  tMax=min(tMax,12000.);

  // ── Raymarching ────────────────────────────────────────
  float stepSz=(tMax-tMin)/float(STEPS);
  // Dither the start offset (blue-noise inspired) to break banding
  float dither=fract(sin(dot(vUv,vec2(12.9898,78.233))+time*.13)*43758.5453);
  float t=tMin+dither*stepSz;

  float transmit=1.;    // Beer-Lambert accumulated transmittance
  vec3  scatter=vec3(0.); // accumulated in-scattered light

  // Sun & sky color (RAGE sky irradiance contribution)
  float sunH=clamp(sunDir.y,.0,1.);
  vec3 sunCol=mix(vec3(1.3,.65,.2),vec3(1.2,1.0,.85),sunH);// warm horizon → white zenith
  vec3 skyCol=vec3(.35,.55,.82)*(.6+.4*sunH);              // ambient sky blue

  float cosA=dot(rd,sunDir);
  float phase=mix(hg(cosA,.65),hg(cosA,-.25),.35); // forward + slight backscatter

  for(int i=0;i<STEPS;i++){
    if(t>tMax)break;
    vec3 pos=camPos+rd*t;
    float dens=cloudDensity(pos,time);
    if(dens>.001){
      // Beer-Lambert step absorption
      float dT=exp(-dens*stepSz*68.);
      // Light energy from sun march
      float le=lightMarch(pos,stepSz,time);
      // In-scatter: sun direct + ambient sky
      vec3 s=(sunCol*le*phase*4.2+skyCol*.38)*dens*stepSz;
      scatter+=s*transmit;
      transmit*=dT;
      if(transmit<.01)break;
    }
    t+=stepSz;
  }

  // ── Horizon atmospheric fade (GTA V ring fades near horizon) ──
  float horizFade=smoothstep(-.04,.22,rd.y);
  float cloudOpacity=(1.-transmit)*horizFade;

  // Soft-blend cloud edges
  scatter*=horizFade;

  // Output: rgb=cloud light, a=transmittance (1=sky, 0=full cloud)
  gl_FragColor=vec4(scatter,1.-cloudOpacity);
}`;

// Composite: implements GTA V's Uncharted 2 filmic tonemapping
// Formula reverse-engineered from GTA V shader bytecode by Adrian Courrèges (2015):
// f(x) = ((x(Ax+BC)+DE)/(x(Ax+B)+DF)) - E/F  — the Hable/Uncharted 2 operator
const FS_COMPOSITE=`
precision highp float;
uniform sampler2D tScene,tBloom,tSSAO,tGodRay,tDepth,tCloud;
uniform vec2 resolution;
uniform float time,bloomStr,ssaoStr,godRayStr,exposure,near,far;
varying vec2 vUv;

// ── Uncharted 2 Tonemapping — GTA V's exact operator ──────
vec3 U2(vec3 x){const float A=.15,B=.5,C=.1,D=.2,E=.02,F=.3;return((x*(A*x+C*B)+D*E)/(x*(A*x+B)+D*F))-E/F;}
vec3 tonemap(vec3 c){c*=exposure*2.;const float W=11.2;return U2(c)/U2(vec3(W));}

// ── GTA V color grade: warm amber shadows, cool teal highlights ──
vec3 colorGrade(vec3 c){
  float lum=dot(c,vec3(0.2126,0.7152,0.0722));
  vec3 shd=vec3(1.05,.93,.80),hlt=vec3(.88,.98,1.10);
  c*=mix(shd,hlt,smoothstep(0.,.85,lum));
  c=c*c*(3.-2.*c);          // contrast S-curve
  c=mix(c,c*c,.10);
  vec3 gray=vec3(dot(c,vec3(.2126,.7152,.0722)));
  c=mix(gray,c,1.20);       // saturation boost
  c=c*.95+.018;             // lift blacks slightly (GTA V doesn't crush)
  return max(c,0.);
}

// ── Depth of Field (subtle, background blur) ──────────────
vec3 dof(vec2 uv,float d){
  float z=near*far/(far-d*(far-near));
  float coc=clamp((z-22.)/70.,0.,1.);coc*=coc;
  if(coc<.01)return texture2D(tScene,uv).rgb;
  vec3 blurred=vec3(0.);float w=0.;
  float r=coc*5./max(resolution.x,resolution.y);
  for(int x=-2;x<=2;x++){for(int y=-2;y<=2;y++){
    vec2 off=vec2(float(x),float(y))*r;
    blurred+=texture2D(tScene,clamp(uv+off,0.,1.)).rgb;w+=1.;
  }}
  return mix(texture2D(tScene,uv).rgb,blurred/w,coc*.5);
}

void main(){
  float depth=texture2D(tDepth,vUv).r;
  vec3 c=dof(vUv,depth);
  // Cloud layer (RAGE volumetric: blend over sky pixels)
  vec4 cloud=texture2D(tCloud,vUv);
  // cloud.rgb = in-scattered light, cloud.a = cloud opacity (0=sky, 1=full cloud)
  c=mix(c,c*cloud.a+cloud.rgb,cloud.a);
  // SSAO
  float ao=texture2D(tSSAO,vUv).r;
  c*=mix(1.,ao,ssaoStr);
  // Bloom
  c+=texture2D(tBloom,vUv).rgb*bloomStr;
  // God Rays
  c+=texture2D(tGodRay,vUv).rgb*godRayStr;
  // Tonemap (Uncharted 2 / GTA V)
  c=tonemap(c);
  // Color grade (GTA V palette)
  c=colorGrade(c);
  // Chromatic Aberration (lens fringing at edges)
  float caStr=.0028;
  vec2 caOff=(vUv-.5)*caStr;
  c.r=mix(c.r,texture2D(tScene,clamp(vUv+caOff,0.,1.)).r,.5);
  c.b=mix(c.b,texture2D(tScene,clamp(vUv-caOff,0.,1.)).b,.5);
  // Vignette (soft GTA V style)
  float vign=smoothstep(.84,.30,length(vUv-.5)*1.42);
  c*=mix(.68,1.,vign);
  // Film grain
  float grain=fract(sin(dot(vUv+fract(time*.07),vec2(12.9898,78.233)))*43758.5453)-.5;
  c+=grain*.025;
  // Gamma (linear → sRGB, we handle it ourselves)
  c=pow(max(c,0.),vec3(1./2.2));
  gl_FragColor=vec4(c,1.);
}`;

class RageFX{
  constructor(renderer,w,h){
    this.ren=renderer;this.enabled=true;this.time=0;
    this.sunDir=new THREE.Vector3(80,90,60).normalize();
    this._sunSP=new THREE.Vector2(.72,.78);
    this._cam=new THREE.OrthographicCamera(-1,1,1,-1,0,1);
    this._sc=new THREE.Scene();
    this._mesh=new THREE.Mesh(new THREE.PlaneGeometry(2,2));
    this._sc.add(this._mesh);
    this._build(w,h);
  }
  _rt(w,h,opts={}){
    return new THREE.WebGLRenderTarget(w,h,{
      format:THREE.RGBAFormat,type:THREE.UnsignedByteType,
      minFilter:THREE.LinearFilter,magFilter:THREE.LinearFilter,
      depthBuffer:false,stencilBuffer:false,...opts});
  }
  _build(w,h){
    this.w=w;this.h=h;
    const hw=Math.max(1,w>>1),hh=Math.max(1,h>>1);
    const dt=new THREE.DepthTexture(w,h);dt.type=THREE.UnsignedShortType;
    const useHalf=this.ren.capabilities&&this.ren.capabilities.isWebGL2;
    this.rtScene=new THREE.WebGLRenderTarget(w,h,{
      format:THREE.RGBAFormat,type:useHalf?THREE.HalfFloatType:THREE.FloatType,
      minFilter:THREE.LinearFilter,magFilter:THREE.LinearFilter,
      depthTexture:dt,depthBuffer:true,stencilBuffer:false});
    this.dt=dt;
    this.rtBright=this._rt(hw,hh);
    this.rtBloom=[this._rt(hw,hh),this._rt(hw,hh)];
    this.rtSSAO=this._rt(hw,hh);
    this.rtSSAO2=this._rt(hw,hh);
    this.rtGodRay=this._rt(hw,hh);
    this.rtCloud=this._rt(hw,hh);  // cloud layer at half-res (GTA V perf trick)
  }
  resize(w,h){
    [this.rtScene,this.rtBright,...this.rtBloom,this.rtSSAO,this.rtSSAO2,this.rtGodRay,this.rtCloud].forEach(r=>r.dispose());
    this._build(w,h);
  }
  _pass(fs,uniforms,rt){
    const mat=new THREE.ShaderMaterial({uniforms,vertexShader:VS_QUAD,fragmentShader:fs,depthTest:false,depthWrite:false});
    this._mesh.material=mat;
    this.ren.setRenderTarget(rt||null);
    this.ren.render(this._sc,this._cam);
    mat.dispose();
  }
  updateSun(cam){
    const sp=this.sunDir.clone().multiplyScalar(500).add(cam.position);
    sp.project(cam);
    this._sunSP.set(sp.x*.5+.5,sp.y*.5+.5);
  }
  render(scene,cam,dt){
    this.time+=dt;
    if(!this.enabled){this.ren.setRenderTarget(null);this.ren.render(scene,cam);return;}
    const ren=this.ren,hw=Math.max(1,this.w>>1),hh=Math.max(1,this.h>>1);
    const res=new THREE.Vector2(this.w,this.h),resH=new THREE.Vector2(hw,hh);
    // 1. Scene → HDR buffer
    ren.setRenderTarget(this.rtScene);ren.render(scene,cam);
    // 2. Bright pass
    this._pass(FS_BRIGHT,{tDiffuse:{value:this.rtScene.texture},threshold:{value:.62}},this.rtBright);
    // 3. Bloom — 4 iterations of separable Gaussian blur
    for(let i=0;i<4;i++){
      this._pass(FS_BLUR,{tDiffuse:{value:i===0?this.rtBright.texture:this.rtBloom[1].texture},
        resolution:{value:resH},direction:{value:new THREE.Vector2(1,0)}},this.rtBloom[0]);
      this._pass(FS_BLUR,{tDiffuse:{value:this.rtBloom[0].texture},
        resolution:{value:resH},direction:{value:new THREE.Vector2(0,1)}},this.rtBloom[1]);
    }
    // 4. SSAO + blur
    this._pass(FS_SSAO,{tDepth:{value:this.dt},resolution:{value:res},time:{value:this.time}},this.rtSSAO);
    this._pass(FS_BLUR,{tDiffuse:{value:this.rtSSAO.texture},resolution:{value:resH},direction:{value:new THREE.Vector2(1,0)}},this.rtSSAO2);
    this._pass(FS_BLUR,{tDiffuse:{value:this.rtSSAO2.texture},resolution:{value:resH},direction:{value:new THREE.Vector2(0,1)}},this.rtSSAO);
    // 5. God rays (volumetric light shafts)
    this.updateSun(cam);
    this._pass(FS_GODRAY,{tDiffuse:{value:this.rtScene.texture},sunPos:{value:this._sunSP},
      exposure:{value:.2},decay:{value:.95},density:{value:.9},weight:{value:.4}},this.rtGodRay);
    // 6. Volumetric cloud pass (RAGE raymarching engine — half-res)
    const invVP=new THREE.Matrix4().multiplyMatrices(cam.projectionMatrix,cam.matrixWorldInverse).invert();
    this._pass(FS_CLOUDS,{
      camPos:{value:cam.position.clone()},
      sunDir:{value:this.sunDir.clone()},
      invViewProj:{value:invVP},
      time:{value:this.time},
      tDepth:{value:this.dt},
      resolution:{value:res}
    },this.rtCloud);
    // 7. Composite → screen
    this._pass(FS_COMPOSITE,{
      tScene:{value:this.rtScene.texture},tBloom:{value:this.rtBloom[1].texture},
      tSSAO:{value:this.rtSSAO.texture},tGodRay:{value:this.rtGodRay.texture},
      tCloud:{value:this.rtCloud.texture},
      tDepth:{value:this.dt},resolution:{value:res},time:{value:this.time},
      bloomStr:{value:.20},ssaoStr:{value:.62},godRayStr:{value:.065},
      exposure:{value:1.08},near:{value:cam.near},far:{value:cam.far}
    },null);
  }
}

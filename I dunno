<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>APEX PROTOCOL — TPS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --c:#00d4ff;--c2:#ff6b00;--bg:#060810;
  --panel:rgba(6,8,16,0.94);--text:#fff;--muted:#7a8fa8;
  --danger:#ff2244;--ok:#00ff88;--font-d:'Orbitron',monospace;
  --font-b:'Rajdhani',sans-serif;
}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--font-b);user-select:none}

/* CANVAS */
#gc{position:fixed;inset:0;display:none;cursor:crosshair}

/* ========== LOADING ========== */
#ls{position:fixed;inset:0;z-index:999;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px}
.lt{font-family:var(--font-d);font-size:11px;letter-spacing:.6em;color:var(--c);text-transform:uppercase}
.lb{width:280px;height:2px;background:rgba(255,255,255,.08);overflow:hidden;border-radius:1px}
.lf{height:100%;background:var(--c);box-shadow:0 0 12px var(--c);animation:lf 2s cubic-bezier(.4,0,.2,1) forwards}
@keyframes lf{from{width:0}to{width:100%}}
.ld{display:flex;gap:5px}
.ld span{width:5px;height:5px;border-radius:50%;background:var(--c);opacity:.25;animation:ld 1.4s ease-in-out infinite}
.ld span:nth-child(2){animation-delay:.2s}.ld span:nth-child(3){animation-delay:.4s}
@keyframes ld{0%,80%,100%{opacity:.25;transform:scale(1)}40%{opacity:1;transform:scale(1.5)}}

/* ========== MAIN MENU ========== */
#mm{position:fixed;inset:0;z-index:100;display:none;flex-direction:column;align-items:center;justify-content:center;overflow:hidden}
#mm::before{content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(90deg,transparent,transparent 80px,rgba(0,212,255,.025) 80px,rgba(0,212,255,.025) 81px),
             repeating-linear-gradient(0,transparent,transparent 80px,rgba(0,212,255,.025) 80px,rgba(0,212,255,.025) 81px);
  animation:gs 25s linear infinite}
@keyframes gs{to{background-position:0 100px}}
#mm::after{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 60% at 50% 60%,rgba(0,212,255,.06) 0,transparent 70%)}
.ml{font-family:var(--font-d);font-size:clamp(36px,7vw,80px);font-weight:900;letter-spacing:.18em;
  text-shadow:0 0 40px var(--c),0 0 100px rgba(0,212,255,.2);
  opacity:0;transform:translateY(-24px);animation:lo 1s cubic-bezier(.16,1,.3,1) .4s forwards;position:relative;z-index:1}
.ms{font-size:11px;letter-spacing:.6em;color:var(--c);text-transform:uppercase;margin-top:10px;margin-bottom:70px;
  opacity:0;animation:lo .8s ease .9s forwards;position:relative;z-index:1}
@keyframes lo{to{opacity:1;transform:none}}
.mb-wrap{display:flex;flex-direction:column;gap:14px;position:relative;z-index:1}
.mb{
  width:300px;height:58px;background:transparent;border:1px solid rgba(0,212,255,.25);
  color:var(--text);font-family:var(--font-d);font-size:12px;font-weight:700;letter-spacing:.35em;
  text-transform:uppercase;cursor:pointer;position:relative;overflow:hidden;
  clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));
  opacity:0;transform:translateX(-32px);
  transition:border-color .3s,color .3s,transform .3s cubic-bezier(.16,1,.3,1),box-shadow .3s,background .3s}
.mb:nth-child(1){animation:lo .6s cubic-bezier(.16,1,.3,1) 1s forwards}
.mb:nth-child(2){animation:lo .6s cubic-bezier(.16,1,.3,1) 1.15s forwards}
.mb:nth-child(3){animation:lo .6s cubic-bezier(.16,1,.3,1) 1.3s forwards}
.mb::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(0,212,255,.07),transparent);
  transform:translateX(-100%);transition:transform .45s ease}
.mb::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--c);
  box-shadow:0 0 8px var(--c);transition:width .35s ease}
.mb:hover{border-color:var(--c);color:var(--c);transform:translateX(10px);
  box-shadow:-4px 0 24px rgba(0,212,255,.18),inset 0 0 20px rgba(0,212,255,.04)}
.mb:hover::before{transform:translateX(100%)}
.mb:hover::after{width:100%}
.mb:active{transform:translateX(5px) scale(.975);background:rgba(0,212,255,.08);transition:all .07s}

/* ========== SETTINGS ========== */
#sp{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;
  background:rgba(0,0,0,.75);backdrop-filter:blur(10px)}
#sp.on{display:flex;animation:fi .35s ease}
@keyframes fi{from{opacity:0}to{opacity:1}}
.sb{background:var(--panel);border:1px solid rgba(0,212,255,.18);width:660px;max-height:82vh;overflow-y:auto;
  padding:36px 40px;position:relative;
  clip-path:polygon(0 0,calc(100% - 18px) 0,100% 18px,100% 100%,18px 100%,0 calc(100% - 18px));
  animation:si .4s cubic-bezier(.16,1,.3,1)}
@keyframes si{from{transform:translateY(28px) scale(.96);opacity:0}to{transform:none;opacity:1}}
.st{font-family:var(--font-d);font-size:20px;letter-spacing:.3em;color:var(--c);
  margin-bottom:28px;padding-bottom:14px;border-bottom:1px solid rgba(0,212,255,.15)}
.stabs{display:flex;gap:6px;margin-bottom:28px}
.stab{padding:7px 18px;background:transparent;border:1px solid rgba(255,255,255,.1);color:var(--muted);
  font-family:var(--font-b);font-size:12px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;
  transition:all .22s ease}
.stab:hover{border-color:var(--c);color:var(--c);transform:translateY(-2px)}
.stab.on{background:rgba(0,212,255,.1);border-color:var(--c);color:var(--c);box-shadow:0 3px 16px rgba(0,212,255,.12)}
.ss{display:none}.ss.on{display:block}
.sr{display:flex;align-items:center;justify-content:space-between;padding:15px 0;
  border-bottom:1px solid rgba(255,255,255,.05)}
.sr:last-child{border-bottom:none}
.sr-anim{opacity:0;animation:ri .3s ease forwards}
.sr:nth-child(1){animation-delay:.04s}.sr:nth-child(2){animation-delay:.08s}.sr:nth-child(3){animation-delay:.12s}
.sr:nth-child(4){animation-delay:.16s}.sr:nth-child(5){animation-delay:.20s}.sr:nth-child(6){animation-delay:.24s}
@keyframes ri{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:none}}
.sl{font-size:14px;font-weight:600;letter-spacing:.08em}
.sd{font-size:11px;color:var(--muted);margin-top:2px}
.qo{display:flex;gap:3px}
.qb{padding:5px 13px;background:transparent;border:1px solid rgba(255,255,255,.1);color:var(--muted);
  font-family:var(--font-b);font-size:11px;font-weight:600;letter-spacing:.1em;cursor:pointer;transition:all .2s}
.qb:hover{border-color:var(--c);color:var(--c)}
.qb.on{background:var(--c);border-color:var(--c);color:#000;font-weight:700}
.sw{display:flex;align-items:center;gap:9px}
.si{-webkit-appearance:none;width:150px;height:3px;background:rgba(255,255,255,.1);outline:none}
.si::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;background:var(--c);
  border-radius:50%;cursor:pointer;box-shadow:0 0 8px var(--c);transition:transform .2s}
.si::-webkit-slider-thumb:hover{transform:scale(1.35)}
.sv{font-size:12px;color:var(--c);font-weight:700;width:44px;text-align:right}
.tg{width:44px;height:22px;background:rgba(255,255,255,.1);border-radius:11px;position:relative;cursor:pointer;
  transition:background .3s;border:1px solid rgba(255,255,255,.12)}
.tg.on{background:rgba(0,212,255,.28);border-color:var(--c)}
.tg::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;background:var(--muted);
  border-radius:50%;transition:all .3s cubic-bezier(.34,1.56,.64,1)}
.tg.on::after{left:24px;background:var(--c);box-shadow:0 0 7px var(--c)}
.sc{position:absolute;top:18px;right:18px;width:34px;height:34px;background:transparent;
  border:1px solid rgba(255,255,255,.12);color:var(--muted);font-size:17px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:all .2s}
.sc:hover{border-color:var(--danger);color:var(--danger);transform:rotate(90deg);box-shadow:0 0 12px rgba(255,34,68,.25)}
/* scrollbar */
.sb::-webkit-scrollbar{width:3px}
.sb::-webkit-scrollbar-thumb{background:rgba(0,212,255,.25);border-radius:2px}

/* ========== HUD ========== */
#hud{position:fixed;inset:0;pointer-events:none;z-index:50;display:none}
#hud.on{display:block}
/* crosshair */
.xh{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:22px;height:22px;transition:all .1s ease}
.xh div{position:absolute;background:rgba(255,255,255,.92);border-radius:1px;box-shadow:0 0 3px rgba(0,0,0,.9)}
.xh .t{width:2px;height:7px;top:0;left:50%;transform:translateX(-50%)}
.xh .b{width:2px;height:7px;bottom:0;left:50%;transform:translateX(-50%)}
.xh .l{height:2px;width:7px;left:0;top:50%;transform:translateY(-50%)}
.xh .r{height:2px;width:7px;right:0;top:50%;transform:translateY(-50%)}
.xh .c{width:2px;height:2px;top:50%;left:50%;transform:translate(-50%,-50%);border-radius:50%}
.xh.ads{opacity:0}
/* health */
.hw{position:absolute;bottom:136px;left:36px}
.hl{font-size:10px;letter-spacing:.25em;color:var(--muted);text-transform:uppercase;margin-bottom:5px}
.hbb{width:220px;height:7px;background:rgba(255,255,255,.08);border-radius:4px;overflow:hidden}
.hbf{height:100%;background:linear-gradient(90deg,#00ff88,#00d4ff);border-radius:4px;
  transition:width .45s cubic-bezier(.16,1,.3,1);box-shadow:0 0 10px rgba(0,255,136,.35)}
.hn{font-family:var(--font-d);font-size:30px;font-weight:700;margin-top:4px;line-height:1}
.shb{width:160px;height:4px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;margin-top:6px}
.shf{height:100%;background:linear-gradient(90deg,#4488ff,var(--c));border-radius:3px;
  transition:width .45s cubic-bezier(.16,1,.3,1);box-shadow:0 0 7px rgba(0,212,255,.35);width:75%}
/* ammo */
.aw{position:absolute;bottom:136px;right:36px;text-align:right}
.am{font-family:var(--font-d);font-size:50px;font-weight:700;line-height:1;text-shadow:0 0 20px rgba(255,255,255,.15)}
.ar{font-family:var(--font-d);font-size:18px;color:var(--muted);margin-top:3px}
/* weapon name */
.wn{position:absolute;bottom:158px;right:36px;font-family:var(--font-d);font-size:13px;letter-spacing:.3em;
  opacity:0;transform:translateX(14px);transition:all .35s cubic-bezier(.16,1,.3,1);text-align:right;color:var(--text)}
.wn.on{opacity:1;transform:none}
/* sprint */
.si2{position:absolute;bottom:86px;left:50%;transform:translateX(-50%);
  font-size:9px;letter-spacing:.45em;color:var(--c);text-transform:uppercase;opacity:0;transition:opacity .3s}
.si2.on{opacity:1}
/* mantle prompt */
.mp{position:absolute;top:44%;left:50%;transform:translateX(-50%);text-align:center;opacity:0;transition:opacity .2s}
.mp.on{opacity:1}
.mk{width:30px;height:30px;border:2px solid rgba(255,255,255,.7);border-radius:4px;
  display:flex;align-items:center;justify-content:center;font-family:var(--font-d);font-size:11px;
  margin:0 auto 5px;background:rgba(0,0,0,.5)}
.mt{font-size:10px;letter-spacing:.25em;color:rgba(255,255,255,.7);text-transform:uppercase}
/* hit marker */
.hm{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:20px;height:20px;opacity:0;pointer-events:none}
.hm.on{animation:hmf .25s ease forwards}
@keyframes hmf{0%{opacity:1;transform:translate(-50%,-50%) scale(1.6)}100%{opacity:0;transform:translate(-50%,-50%) scale(1)}}
/* leave btn */
.lb2{position:absolute;top:18px;left:18px;width:42px;height:38px;background:rgba(255,34,68,.08);
  border:1px solid rgba(255,34,68,.35);color:var(--danger);font-size:18px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;pointer-events:auto;
  clip-path:polygon(12% 0,100% 0,88% 100%,0 100%);
  transition:all .22s ease}
.lb2:hover{background:rgba(255,34,68,.22);border-color:var(--danger);box-shadow:0 0 18px rgba(255,34,68,.35)}
.lb2:active{transform:scale(.93);transition:all .06s}
/* minimap */
.mm2{position:absolute;top:18px;right:18px;width:130px;height:130px;border-radius:50%;
  border:1px solid rgba(0,212,255,.2);overflow:hidden}
/* notifications */
.nw{position:absolute;top:56px;right:36px;display:flex;flex-direction:column;gap:6px;align-items:flex-end}
.nf{background:rgba(0,0,0,.7);border:1px solid rgba(0,212,255,.28);padding:6px 14px;
  font-size:12px;letter-spacing:.1em;color:var(--c);
  animation:ns .28s ease,nf2 .3s ease 2.7s forwards}
@keyframes ns{from{transform:translateX(16px);opacity:0}to{transform:none;opacity:1}}
@keyframes nf2{to{opacity:0;transform:translateX(12px)}}
/* vignettes */
.dv,.sv2,.av{position:fixed;inset:0;pointer-events:none}
.dv{z-index:49;opacity:0;background:radial-gradient(ellipse at center,transparent 55%,rgba(255,34,68,.45) 100%)}
.dv.on{animation:dvf .55s ease forwards}
@keyframes dvf{0%{opacity:1}100%{opacity:0}}
.sv2{z-index:48;opacity:0;background:radial-gradient(ellipse at center,transparent 45%,rgba(0,212,255,.07) 100%);transition:opacity .5s}
.sv2.on{opacity:1}
.av{z-index:48;opacity:0;background:radial-gradient(circle at center,transparent 30%,rgba(0,0,0,.88) 68%);transition:opacity .14s}
.av.on{opacity:1}

/* ========== ITEM BAR ========== */
#ib{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);
  display:none;gap:7px;z-index:51;align-items:flex-end;pointer-events:auto}
#ib.on{display:flex}
.is{width:74px;height:74px;background:rgba(0,0,0,.68);border:2px solid rgba(255,255,255,.14);
  border-radius:5px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;position:relative;backdrop-filter:blur(12px);
  transform-origin:bottom center;transition:all .22s cubic-bezier(.34,1.56,.64,1)}
.is:hover{border-color:rgba(255,255,255,.4);background:rgba(255,255,255,.07);transform:translateY(-4px)}
.is.sel{width:88px;height:88px;background:rgba(0,0,0,.82);border-color:var(--c);
  transform:translateY(-14px);
  box-shadow:0 0 22px rgba(0,212,255,.38),0 0 44px rgba(0,212,255,.12),inset 0 0 18px rgba(0,212,255,.04)}
.is.sel .isn{color:var(--c)}
.is:active{transform:translateY(-2px) scale(.93);transition:all .06s}
.is.sel:active{transform:translateY(-12px) scale(.93)}
.isn{position:absolute;top:4px;left:5px;font-family:var(--font-d);font-size:9px;font-weight:700;
  color:rgba(255,255,255,.38);transition:color .2s}
.isi{font-size:26px;line-height:1;transition:transform .2s;filter:drop-shadow(0 0 3px rgba(0,0,0,.9))}
.is.sel .isi{transform:scale(1.18)}
.isa{position:absolute;bottom:4px;right:5px;font-family:var(--font-b);font-size:9px;font-weight:700;color:rgba(255,255,255,.55)}
.irb{position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 3px 3px;transition:all .3s}
.is.sel .irb{height:4px;animation:rp 2s ease-in-out infinite}
@keyframes rp{0%,100%{opacity:1}50%{opacity:.55}}
.rc .irb{background:#aaa}
.ru .irb{background:#00cc44;box-shadow:0 0 5px #00cc44}
.rr .irb{background:#08f;box-shadow:0 0 5px #08f}
.re .irb{background:#a0f;box-shadow:0 0 5px #a0f}
.rl .irb{background:#f80;box-shadow:0 0 7px #f80}

/* ========== LEAVE CONFIRM ========== */
#lc{position:fixed;inset:0;z-index:300;display:none;align-items:center;justify-content:center;
  background:rgba(0,0,0,.82);backdrop-filter:blur(14px)}
#lc.on{display:flex;animation:fi .22s ease}
.lcb{background:var(--panel);border:1px solid rgba(255,34,68,.28);padding:40px 48px;text-align:center;
  clip-path:polygon(0 0,calc(100% - 15px) 0,100% 15px,100% 100%,15px 100%,0 calc(100% - 15px));
  animation:si .28s cubic-bezier(.34,1.56,.64,1)}
.lcb h2{font-family:var(--font-d);font-size:20px;letter-spacing:.2em;color:var(--danger);margin-bottom:10px}
.lcb p{font-size:13px;color:var(--muted);margin-bottom:30px;letter-spacing:.05em}
.la{display:flex;gap:14px;justify-content:center}
.ab{padding:13px 38px;font-family:var(--font-d);font-size:11px;font-weight:700;letter-spacing:.3em;
  text-transform:uppercase;cursor:pointer;border-radius:2px;transition:all .2s}
.ab:active{transform:scale(.94);transition:all .05s}
.ac{background:rgba(255,34,68,.12);border:1px solid var(--danger);color:var(--danger)}
.ac:hover{background:rgba(255,34,68,.28);transform:translateY(-2px);box-shadow:0 4px 18px rgba(255,34,68,.25)}
.ax{background:transparent;border:1px solid rgba(255,255,255,.18);color:var(--muted)}
.ax:hover{border-color:rgba(255,255,255,.45);color:var(--text);transform:translateY(-2px)}

/* ========== KILL BANNER ========== */
.kb{position:absolute;top:60px;left:50%;transform:translateX(-50%);
  font-family:var(--font-d);font-size:11px;letter-spacing:.3em;color:var(--ok);text-transform:uppercase;
  opacity:0;pointer-events:none;text-shadow:0 0 12px var(--ok)}
.kb.on{animation:kbf .9s ease forwards}
@keyframes kbf{0%{opacity:1;transform:translateX(-50%) translateY(0)}
  30%{opacity:1;transform:translateX(-50%) translateY(-6px)}100%{opacity:0;transform:translateX(-50%) translateY(-18px)}}
/* ========== MOBILE CONTROLS ========== */
#mob-ctrl{display:none;position:fixed;inset:0;z-index:55;pointer-events:none}
body.mobile #mob-ctrl{display:block}

/* --- Virtual Joystick --- */
#mob-stick-zone{
  position:absolute;bottom:44px;left:28px;
  width:150px;height:150px;pointer-events:auto;
  touch-action:none}
#mob-outer{
  position:absolute;inset:0;border-radius:50%;
  border:2px solid rgba(0,212,255,.5);
  background:rgba(0,0,0,.32);backdrop-filter:blur(4px)}
#mob-knob{
  position:absolute;width:56px;height:56px;
  background:rgba(0,212,255,.6);border-radius:50%;
  border:2px solid var(--c);
  box-shadow:0 0 16px rgba(0,212,255,.5);
  transform:translate(-50%,-50%);left:50%;top:50%;
  pointer-events:none;transition:box-shadow .1s}

/* --- Look zone (right 60% of screen, invisible) --- */
#mob-look{
  position:absolute;top:0;left:40%;right:0;bottom:200px;
  pointer-events:auto;touch-action:none}

/* --- Action buttons --- */
#mob-actions{
  position:absolute;bottom:30px;right:18px;
  pointer-events:auto;display:grid;
  grid-template-columns:60px 60px 88px;
  grid-template-rows:60px 60px;
  gap:12px;align-items:center;justify-items:center}
.mbt{
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  cursor:pointer;pointer-events:auto;touch-action:manipulation;
  font-size:18px;font-family:var(--font-d);
  background:rgba(0,0,0,.52);border:2px solid rgba(255,255,255,.32);
  color:#fff;user-select:none;-webkit-user-select:none;
  backdrop-filter:blur(8px);
  transition:transform .08s,background .1s;
  -webkit-tap-highlight-color:transparent}
.mbt:active{transform:scale(.84);background:rgba(255,255,255,.18)}
#mob-reload{width:56px;height:56px;font-size:20px;grid-column:1;grid-row:1}
#mob-crouch{width:56px;height:56px;font-size:17px;grid-column:2;grid-row:1}
#mob-ads{
  width:60px;height:60px;font-size:11px;letter-spacing:.05em;
  background:rgba(0,160,255,.38);border-color:rgba(0,212,255,.65);
  grid-column:3;grid-row:1}
#mob-jump{
  width:68px;height:68px;
  background:rgba(30,120,255,.45);border-color:rgba(80,200,255,.75);
  grid-column:1/3;grid-row:2;width:auto;border-radius:32px;padding:0 16px;
  font-size:13px;letter-spacing:.15em}
#mob-fire{
  width:88px;height:88px;font-size:24px;
  background:rgba(210,35,35,.55);border-color:rgba(255,80,80,.75);
  box-shadow:0 0 22px rgba(255,50,50,.35);
  grid-column:3;grid-row:2}

/* --- Mobile HUD adaptations --- */
body.mobile .hw{bottom:210px;left:22px}
body.mobile .hbb{width:150px}
body.mobile .hn{font-size:22px}
body.mobile .shb{width:110px}
body.mobile .aw{bottom:210px;right:220px;text-align:right}
body.mobile .am{font-size:38px}
body.mobile .ar{font-size:13px}
body.mobile .mm2{width:88px;height:88px;border-radius:50%;top:10px;right:10px}
body.mobile .lb2{top:10px;left:10px;width:38px;height:34px}
body.mobile .nw{top:60px;right:16px}

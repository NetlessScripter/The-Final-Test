local function Lerp(a, b, t)
    return a + (b - a) * t
end
local function Clamp(val, min, max)
    return math.max(min, math.min(max, val))
end
local FPSCamera = {}
local function TriggerShake(magnitude, duration)
    State.ShakeMagnitude = math.max(State.ShakeMagnitude, magnitude)
    State.ShakeTimer     = math.max(State.ShakeTimer, duration)
end
function FPSCamera:GetIsADS()      return State.IsADS      end
function FPSCamera:GetIsSprinting() return State.IsSprinting end
function FPSCamera:GetPitch()      return State.Pitch       end
function FPSCamera:GetYaw()        return State.Yaw         end
_G.FPSCamera = FPSCamera


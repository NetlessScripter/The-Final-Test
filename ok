local function hideCharacterHead()
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name == "Head" then
            part.Transparency = 1
            part.CastShadow = false
        elseif part:IsA("Decal") and part.Parent.Name == "Head" then
            part.Transparency = 1
        elseif part:IsA("Accessory") then
            local handle = part:FindFirstChildOfClass("Part") or part:FindFirstChildOfClass("MeshPart") or part:FindFirstChildOfClass("SpecialMesh") and part:FindFirstChild("Handle")
            if handle then
                handle.Transparency = 1
                handle.CastShadow = false
            end
        elseif part:IsA("SpecialMesh") and part.Parent.Name == "Head" then
            part.Scale = Vector3.new(0, 0, 0)
        end
    end
end

hideCharacterHead()

local function Lerp(a, b, t)        return a + (b - a) * t                    end
local function Clamp(val, mn, mx)   return math.max(mn, math.min(mx, val))    end
local function TriggerShake(magnitude, duration)
    State.ShakeMagnitude = math.max(State.ShakeMagnitude, magnitude)
    State.ShakeTimer     = math.max(State.ShakeTimer, duration)
end

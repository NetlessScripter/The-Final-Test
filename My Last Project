local activeBlips = {}
local function makeRoundDot(color, size)
    local f = Instance.new("Frame")
    f.Size             = UDim2.new(0, size, 0, size)
    f.AnchorPoint      = Vector2.new(0.5, 0.5)
    f.BackgroundColor3 = color
    f.BorderSizePixel  = 0
    f.ZIndex           = 7
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    local stroke = Instance.new("UIStroke")
    stroke.Color     = Color3.fromRGB(0, 0, 0)
    stroke.Thickness = 1
    stroke.Parent    = f
    return f
end
local function makeEdgeArrow(color, size)
    local f = Instance.new("Frame")
    f.Size                   = UDim2.new(0, size, 0, size)
    f.AnchorPoint            = Vector2.new(0.5, 0.5)
    f.BackgroundTransparency = 1
    f.BorderSizePixel        = 0
    f.ZIndex                 = 8
    local t = Instance.new("TextLabel")
    t.Name                   = "Arrow"
    t.Size                   = UDim2.new(1.4, 0, 1.4, 0)
    t.AnchorPoint            = Vector2.new(0.5, 0.5)
    t.Position               = UDim2.new(0.5, 0, 0.5, 0)
    t.BackgroundTransparency = 1
    t.Text                   = "▸"
    t.TextColor3             = color
    t.TextScaled             = true
    t.Font                   = Enum.Font.GothamBold
    t.ZIndex                 = 8
    t.Parent                 = f
    return f
end
local function addBlip(id, worldPos, color, size)
    size = size or CFG.OSz
    if activeBlips[id] then
        activeBlips[id].worldPos = worldPos
        activeBlips[id].color    = color
        return activeBlips[id]
    end
    local dot  = makeRoundDot(color, size)
    dot.Name   = "Blip_" .. tostring(id)
    dot.Parent = BlipContainer
    local arrow   = makeEdgeArrow(color, size)
    arrow.Name    = "Edge_" .. tostring(id)
    arrow.Visible = false
    arrow.Parent  = EdgeContainer
    activeBlips[id] = {
        frame     = dot,
        edgeArrow = arrow,
        worldPos  = worldPos,
        color     = color,
        size      = size,
    }
    return activeBlips[id]
end
local function removeBlip(id)
    if activeBlips[id] then
        activeBlips[id].frame:Destroy()
        activeBlips[id].edgeArrow:Destroy()
        activeBlips[id] = nil
    end
end
local function setWaypoint(worldPos)
    removeBlip("__waypoint")
    local b = addBlip("__waypoint", worldPos, CFG.COL_YELLOW, CFG.WSz)
    b.frame.Rotation = 45
    for _, c in ipairs(b.frame:GetChildren()) do
        if c:IsA("UICorner") then c:Destroy() end
    end
end
local function clearWaypoint()
    removeBlip("__waypoint")
end
local playerBlipMap = {}
local function onPlayerAdded(p)
    if p == LocalPlayer then return end
    local id = "ply_" .. p.UserId
    playerBlipMap[p] = id
    addBlip(id, Vector3.new(0, 0, 0), CFG.COL_WHITE, CFG.OSz)
end
local function onPlayerRemoving(p)
    if playerBlipMap[p] then
        removeBlip(playerBlipMap[p])
        playerBlipMap[p] = nil
    end
end
for _, p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)
local isExpanded  = false
local lastTapTick = 0
local TWEEN_INFO  = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local function setMinimapSize(expand)
    isExpanded = expand
    local tw, th = expand and CFG.EW or CFG.W, expand and CFG.EH or CFG.H
    TweenService:Create(Container, TWEEN_INFO, { Size = UDim2.new(0, tw, 0, th) }):Play()

    ViewCamera.FieldOfView = expand and CFG.ExpandedFOV or CFG.NormalFOV
end
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == CFG.EXPAND_KEY then
        local now = tick()
        if (now - lastTapTick) <= CFG.DOUBLE_TAP_WINDOW then
            setMinimapSize(not isExpanded)
            lastTapTick = 0
        else
            lastTapTick = now
        end
    end
end)
local cachedStreet = ""
local cachedZone   = ""
local lastZoneTick = 0
local allMapParts  = {}
local function buildCharacterSet()
    local set = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            for _, d in ipairs(p.Character:GetDescendants()) do set[d] = true end
            set[p.Character] = true
        end
    end
    return set
end

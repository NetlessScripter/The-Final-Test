local function hideCharacterHead()
    if not Character then return end
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name == "Head" then
            part.Transparency = 1
            part.CastShadow   = false
        elseif part:IsA("Decal") and part.Parent.Name == "Head" then
            part.Transparency = 1
        elseif part:IsA("Accessory") then
            local handle = part:FindFirstChildOfClass("Part")
                        or part:FindFirstChildOfClass("MeshPart")
            if handle then
                handle.Transparency = 1
                handle.CastShadow   = false
            end
        elseif part:IsA("SpecialMesh") and part.Parent.Name == "Head" then
            part.Scale = Vector3.new(0, 0, 0)
        end
    end
end
local function setupCharacter(char)
    Character        = char
    HumanoidRootPart = char:WaitForChild("HumanoidRootPart")
    Humanoid         = char:WaitForChild("Humanoid")
    Head             = char:WaitForChild("Head")
    hideCharacterHead()
end

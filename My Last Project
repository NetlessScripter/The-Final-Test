local function makeBar(isOutline)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = isOutline and CH.OutlineCol or CH.Color
    f.BorderSizePixel  = 0
    f.AnchorPoint      = Vector2.new(0.5, 0.5)
    f.ZIndex           = isOutline and 9 or 10
    f.Parent           = CrosshairGui
    return f
end


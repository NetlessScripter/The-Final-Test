    RunService:BindToRenderStep("FPS_Death", Enum.RenderPriority.Camera.Value + 2, function(dt)
        State.DeathRoll = Lerp(State.DeathRoll, CONFIG.Death_RollAmount * rollDir, dt * 4)
    end)
end)
RunService.Heartbeat:Connect(function(dt)
    if not HumanoidRootPart then return end
    local vel  = HumanoidRootPart.AssemblyLinearVelocity
    local velY = vel.Y
    if State.PrevVelocityY < -20 and velY > -5 and Humanoid.FloorMaterial ~= Enum.Material.Air then
        local impact = math.abs(State.PrevVelocityY)
        local mag    = Clamp(impact / 80, 0, 1) * CONFIG.Shake_LandMag * 2 + CONFIG.Shake_LandMag
        TriggerShake(mag, CONFIG.Shake_LandDuration)
    end
    local moveSpeed              = Vector2.new(vel.X, vel.Z).Magnitude
    local isActivelySprintMoving = State.IsSprinting and moveSpeed > 0.5
    if isActivelySprintMoving then
        State.Energy           = math.max(0, State.Energy - CONFIG.Energy_SprintDrain * dt)
        State.EnergyRegenDelay = 3
        if State.Energy <= 0 then
            State.IsSprinting  = false
            Humanoid.WalkSpeed = CONFIG.WalkSpeed
        end
    else
        if State.EnergyRegenDelay > 0 then
            State.EnergyRegenDelay = math.max(0, State.EnergyRegenDelay - dt)
        else
            State.Energy = math.min(CONFIG.Energy_Max, State.Energy + CONFIG.Energy_RegenRate * dt)
        end
    end
    updateEnergyBar()
    State.PrevVelocityY = velY
end)
RunService:BindToRenderStep("FPS_Camera_Main", Enum.RenderPriority.Camera.Value + 1, function(dt)
    if State.IsDead or not HumanoidRootPart then return end
    dt = math.min(dt, 0.05)
    local sens = IsMobile
        and (State.IsADS and CONFIG.SensitivityMobileADS or CONFIG.SensitivityMobile)
        or  (State.IsADS and CONFIG.SensitivityADS       or CONFIG.Sensitivity)
    local dX = mouseDeltaX * sens
    local dY = mouseDeltaY * sens * (CONFIG.InvertY and -1 or 1)
    mouseDeltaX = 0
    mouseDeltaY = 0
    State.YawVelocity   = State.YawVelocity   * CONFIG.LookMomentum - dX
    State.PitchVelocity = State.PitchVelocity * CONFIG.LookMomentum - dY
    State.Yaw   = State.Yaw   + State.YawVelocity
    State.Pitch = Clamp(State.Pitch + State.PitchVelocity, -CONFIG.MaxLookDown, CONFIG.MaxLookUp)
    local rootCF    = HumanoidRootPart.CFrame
    local camOrigin = CFrame.new(Head.Position + Vector3.new(0, 0.3, 0))
    local baseCF    = camOrigin
        * CFrame.Angles(0, math.rad(State.Yaw), 0)
        * CFrame.Angles(math.rad(State.Pitch), 0, 0)
    local bobOffset = Vector3.new(0, 0, 0)
    if CONFIG.Bob_Enabled then
        local vel   = HumanoidRootPart.AssemblyLinearVelocity
        local speed = Vector2.new(vel.X, vel.Z).Magnitude
        if speed > 0.5 and Humanoid.FloorMaterial ~= Enum.Material.Air then
            local bobSpeed = State.IsSprinting and CONFIG.Bob_SprintSpeed or CONFIG.Bob_WalkSpeed
            local bobAmp   = State.IsSprinting and CONFIG.Bob_SprintAmplitude or CONFIG.Bob_WalkAmplitude
            if State.IsADS then bobAmp = bobAmp * 0.3 end
            State.BobTimer = State.BobTimer + dt * bobSpeed
            State.BobOffset = Vector3.new(
                math.cos(State.BobTimer * 0.5) * bobAmp * 0.5,
                math.sin(State.BobTimer)        * bobAmp * CONFIG.Bob_YRatio,
                0
            )
        else
            State.BobOffset = State.BobOffset:Lerp(Vector3.new(0, 0, 0), dt * 8)
        end
        bobOffset = State.BobOffset
    end
    local swayRot = CFrame.identity
    if CONFIG.Sway_Enabled then
        local mouseSwayTarget = Vector2.new(
            Clamp(-dX * CONFIG.Sway_MouseAmount, -CONFIG.Sway_MaxRot, CONFIG.Sway_MaxRot),
            Clamp(-dY * CONFIG.Sway_MouseAmount, -CONFIG.Sway_MaxRot, CONFIG.Sway_MaxRot)
        )
        local springForceX = (mouseSwayTarget.X - State.SwayRot.X) * CONFIG.Sway_Stiffness
        local springForceY = (mouseSwayTarget.Y - State.SwayRot.Y) * CONFIG.Sway_Stiffness
        State.SwayVelocity = Vector2.new(
            State.SwayVelocity.X + (springForceX - State.SwayVelocity.X * CONFIG.Sway_Damping) * dt,
            State.SwayVelocity.Y + (springForceY - State.SwayVelocity.Y * CONFIG.Sway_Damping) * dt
        )
        State.SwayRot = Vector2.new(
            Clamp(State.SwayRot.X + State.SwayVelocity.X * dt, -CONFIG.Sway_MaxRot, CONFIG.Sway_MaxRot),
            Clamp(State.SwayRot.Y + State.SwayVelocity.Y * dt, -CONFIG.Sway_MaxRot, CONFIG.Sway_MaxRot)
        )
        local vel        = HumanoidRootPart.AssemblyLinearVelocity
        local strafeAmt  = Clamp(vel:Dot(rootCF.RightVector)  / 20, -1, 1) * CONFIG.Sway_MoveAmount
        local forwardAmt = Clamp(vel:Dot(rootCF.LookVector)   / 20, -1, 1) * CONFIG.Sway_MoveAmount
        State.SwayMoveRot = Vector2.new(
            Lerp(State.SwayMoveRot.X, strafeAmt,  dt * 6),
            Lerp(State.SwayMoveRot.Y, forwardAmt, dt * 6)
        )
        swayRot = CFrame.Angles(
            math.rad(State.SwayRot.Y * CONFIG.Sway_MouseRotation + State.SwayMoveRot.Y * CONFIG.Sway_MoveRotation),
            math.rad(State.SwayRot.X * CONFIG.Sway_MouseRotation + State.SwayMoveRot.X * CONFIG.Sway_MoveRotation),
            math.rad(State.SwayRot.X * CONFIG.Sway_MouseRotation * 0.5)
        )
    end
    local tiltAngle = 0
    if CONFIG.Tilt_Enabled then
        local strafeDot = HumanoidRootPart.AssemblyLinearVelocity:Dot(rootCF.RightVector)
        State.TargetTilt  = -Clamp(strafeDot / 16, -1, 1) * CONFIG.Tilt_Amount
        State.CurrentTilt = Lerp(State.CurrentTilt, State.TargetTilt, dt * CONFIG.Tilt_Speed)
        tiltAngle         = State.CurrentTilt
    end
    local shakeOffset = Vector3.new(0, 0, 0)
    if State.ShakeTimer > 0 then
        State.ShakeTimer  = State.ShakeTimer - dt
        local intensity   = State.ShakeMagnitude * math.max(0, State.ShakeTimer / 0.3)
        shakeOffset = Vector3.new(
            (math.random() * 2 - 1) * intensity,
            (math.random() * 2 - 1) * intensity,
            0
        )
        if State.ShakeTimer <= 0 then State.ShakeMagnitude = 0 end
    end
    State.ShakeOffset = State.ShakeOffset:Lerp(shakeOffset, dt * CONFIG.Shake_DecaySpeed)
    local breatheOffset = Vector3.new(0, 0, 0)
    if CONFIG.Breathe_Enabled then
        State.BreatheTimer = State.BreatheTimer + dt * CONFIG.Breathe_Speed
        local breatheAmt   = State.IsADS and CONFIG.Breathe_ADS_Amount or CONFIG.Breathe_Amount
        breatheOffset = Vector3.new(
            math.sin(State.BreatheTimer * 0.9) * breatheAmt,
            math.sin(State.BreatheTimer * 1.1) * breatheAmt * 0.5,
            0
        )
    end
    local vel2D = Vector2.new(HumanoidRootPart.AssemblyLinearVelocity.X, HumanoidRootPart.AssemblyLinearVelocity.Z).Magnitude
    local targetFOV = State.IsADS and CONFIG.FOV_ADS
        or (State.IsSprinting and vel2D > 0.5 and CONFIG.FOV_Sprint)
        or CONFIG.FOV_Normal
    State.CurrentFOV   = Lerp(State.CurrentFOV, targetFOV, dt * CONFIG.FOV_Speed)
    Camera.FieldOfView = State.CurrentFOV
    Camera.CFrame = baseCF
        * swayRot
        * CFrame.Angles(0, 0, math.rad(tiltAngle + State.DeathRoll))
        * CFrame.new(bobOffset + State.ShakeOffset + breatheOffset)
    HumanoidRootPart.CFrame = CFrame.new(HumanoidRootPart.Position)
        * CFrame.Angles(0, math.rad(State.Yaw), 0)
end)

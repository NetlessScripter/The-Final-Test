local currentGap = CH.BaseGap

local function updateBars(gap)
    local os = CH.OutlineSize
    local cx, cy = 0.5, 0.5

    dot.Size      = UDim2.new(0, CH.DotSize,      0, CH.DotSize)
    dot.Position  = UDim2.new(cx, 0, cy, 0)
    oDot.Size     = UDim2.new(0, CH.DotSize+os*2, 0, CH.DotSize+os*2)
    oDot.Position = dot.Position

    local ringDiam = gap * 2 + 40
    ring.Size = UDim2.new(0, ringDiam, 0, ringDiam)
end

RunService.RenderStepped:Connect(function(dt)
    if State.IsADS then
        dot.Visible  = false  oDot.Visible = false
        ring.Visible = false
        return
    end

    dot.Visible  = true  oDot.Visible = true
    ring.Visible = true

    local targetGap
    if HumanoidRootPart then
        local vel2D = Vector2.new(
            HumanoidRootPart.AssemblyLinearVelocity.X,
            HumanoidRootPart.AssemblyLinearVelocity.Z
        ).Magnitude
        if vel2D > CONFIG.SprintSpeed * 0.6 then
            targetGap = CH.SprintGap
        elseif vel2D > 1 then
            targetGap = CH.MoveGap
        else
            targetGap = CH.IdleGap
        end
    else
        targetGap = CH.IdleGap
    end

    currentGap = currentGap + (targetGap - currentGap) * math.min(1, dt * CH.LerpSpeed)
    updateBars(currentGap)
end)

end)
task.spawn(function()
    RunService.RenderStepped:Wait()
    local charSet = buildCharacterSet()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not charSet[obj] then
            local n = obj.Name
            if n and n ~= "Part" and n ~= "BasePart" and n ~= "Union" and #n > 2 then
                table.insert(allMapParts, obj)
            end
        end
    end
end)
local function refreshZoneInfo()
    if not HumanoidRootPart then return end
    local pos     = HumanoidRootPart.Position
    local closest = math.huge
    local street  = ""
    for _, part in ipairs(allMapParts) do
        local d = (part.Position - pos).Magnitude
        if d < closest then
            closest = d
            local sn = part:GetAttribute("StreetName")
            local zn = part:GetAttribute("ZoneName")
            if sn or zn then
                street     = sn or ""
                cachedZone = zn or ""
            else
                street     = part.Name
                local par  = part.Parent
                cachedZone = (par and par.Name ~= "Workspace" and par ~= workspace)
                             and par.Name or ""
            end
        end
    end
    cachedStreet = street
end
local function worldToUV(worldPos, pPos, hvR, hhR)
    local dx = worldPos.X - pPos.X
    local dz = worldPos.Z - pPos.Z
    return 0.5 + dx / (hhR * 2), 0.5 + dz / (hvR * 2)
end
local EDGE_PAD = 0.055
local function clampToEdge(u, v)
    local inside = u >= EDGE_PAD and u <= 1 - EDGE_PAD and
                   v >= EDGE_PAD and v <= 1 - EDGE_PAD
    if inside then return u, v, 0, false end
    local dx, dy = u - 0.5, v - 0.5
    if dx == 0 and dy == 0 then return 0.5, 0.5, 0, true end
    local t = math.huge
    if math.abs(dx) > 0 then t = math.min(t, (0.5 - EDGE_PAD) / math.abs(dx)) end
    if math.abs(dy) > 0 then t = math.min(t, (0.5 - EDGE_PAD) / math.abs(dy)) end
    return 0.5 + dx * t, 0.5 + dy * t, math.deg(math.atan2(dx, -dy)), true
end
local pulseAlpha   = 0
local pulseDir     = 1
local LOW_HP_FLASH = false
RunService.RenderStepped:Connect(function(dt)
    if not HumanoidRootPart or not Character then return end
    local pPos = HumanoidRootPart.Position
    ViewCamera.CFrame = CFrame.fromMatrix(
        pPos + Vector3.new(0, CFG.CamHeight, 0),
        Vector3.new(1, 0,  0),
        Vector3.new(0, 0, -1),
        Vector3.new(0, 1,  0)
    )
    local look = HumanoidRootPart.CFrame.LookVector
    PlayerBlip.Rotation = math.deg(math.atan2(look.X, -look.Z))
    local fov    = ViewCamera.FieldOfView
    local hvR    = halfVRange(fov)
    local aspect = Container.AbsoluteSize.X / math.max(Container.AbsoluteSize.Y - CFG.BarH * 2, 1)
    local hhR    = hvR * aspect
    local hp    = Humanoid and Humanoid.Health    or 0
    local maxHp = Humanoid and Humanoid.MaxHealth or 100
    local hpPct = math.clamp(hp / math.max(maxHp, 1), 0, 1)
    HpBar.Size  = UDim2.new(hpPct, 0, 1, 0)
    LOW_HP_FLASH = (hpPct * 100) <= CFG.LOW_HP_PCT
    if LOW_HP_FLASH then
        pulseAlpha = pulseAlpha + pulseDir * dt * 3
        if     pulseAlpha >= 1 then pulseAlpha = 1; pulseDir = -1
        elseif pulseAlpha <= 0 then pulseAlpha = 0; pulseDir =  1 end
        HpBar.BackgroundColor3 = Color3.fromRGB(math.floor(180 + 75 * pulseAlpha), 20, 20)
    else
        pulseAlpha             = 0
        HpBar.BackgroundColor3 = CFG.COL_HP_GREEN
    end
    local armorVal = 0
    if Humanoid then
        armorVal = Humanoid:GetAttribute("Armor") or Humanoid:GetAttribute("ArmorPoints") or 0
    end
    ArBar.Size = UDim2.new(math.clamp(armorVal / 100, 0, 1), 0, 1, 0)
    for p, blipId in pairs(playerBlipMap) do
        local bd = activeBlips[blipId]
        if bd and p.Character then
            local pHrp = p.Character:FindFirstChild("HumanoidRootPart")
            if pHrp then bd.worldPos = pHrp.Position end
        end
    end
    for _, bd in pairs(activeBlips) do
        local u, v                = worldToUV(bd.worldPos, pPos, hvR, hhR)
        local eu, ev, ang, isEdge = clampToEdge(u, v)
        if isEdge then
            bd.frame.Visible      = false
            bd.edgeArrow.Visible  = true
            bd.edgeArrow.Position = UDim2.new(eu, 0, ev, 0)
            local arrowGlyph = bd.edgeArrow:FindFirstChild("Arrow")
            if arrowGlyph then arrowGlyph.Rotation = ang end
        else
            bd.frame.Visible     = true
            bd.edgeArrow.Visible = false
            bd.frame.Position    = UDim2.new(u, 0, v, 0)
        end
    end
    local now = tick()
    if now - lastZoneTick >= CFG.ZONE_REFRESH then
        lastZoneTick = now
        task.spawn(refreshZoneInfo)
    end

end)

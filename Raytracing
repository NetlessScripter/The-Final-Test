-- WATER CAUSTICS — unchanged from v2 (already reasonable)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local causticParts   = {}
local causticLights  = {}
local causticOrigins = {}
local causticTime    = 0

for i = 1, CFG.CAUSTIC_PROBES do
    local p, l = makeProbe("Caustic_"..i, 0, CFG.CAUSTIC_RANGE, false)
    causticParts[i]   = p
    causticLights[i]  = l
    causticLights[i].Color = Color3.fromRGB(140, 200, 255)
end

local lastCausticScan = 0

local function scanForCausticPositions(char)
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local center = root.Position

    local waterParams = RaycastParams.new()
    waterParams.FilterType = Enum.RaycastFilterType.Include
    waterParams.FilterDescendantsInstances = { Workspace.Terrain }

    local floorParams = RaycastParams.new()
    floorParams.FilterType = Enum.RaycastFilterType.Exclude
    floorParams.FilterDescendantsInstances = { probeRoot, Workspace.Terrain }
    if char then floorParams.FilterDescendantsInstances = { probeRoot, Workspace.Terrain, char } end

    local found = {}

    for i = 1, CFG.CAUSTIC_PROBES * 3 do
        if #found >= CFG.CAUSTIC_PROBES then break end
        local angle  = i * 2.399963
        local radius = math.sqrt(i / (CFG.CAUSTIC_PROBES * 3)) * CFG.CAUSTIC_SCAN_R
        local ox = math.cos(angle) * radius
        local oz = math.sin(angle) * radius
        local origin = Vector3.new(center.X + ox, center.Y + 20, center.Z + oz)

        local waterHit = Workspace:Raycast(origin, Vector3.new(0,-40,0), waterParams)
        if waterHit and waterHit.Material == Enum.Material.Water then
            local floorHit = Workspace:Raycast(
                waterHit.Position + Vector3.new(0,-0.2,0),
                Vector3.new(0,-30,0), floorParams
            )
            if floorHit then
                table.insert(found, floorHit.Position + Vector3.new(0,0.15,0))
            end
        end
    end

    for i = 1, CFG.CAUSTIC_PROBES do
        if found[i] then
            causticOrigins[i] = found[i]
            causticLights[i].Brightness = 0
        else
            causticOrigins[i] = nil
            causticLights[i].Brightness = 0
        end
    end
end

local function tickCaustics(dt, sunDir)
    causticTime += dt * CFG.CAUSTIC_SPEED
    local sunElev = math.max(0, sunDir.Y)

    for i = 1, CFG.CAUSTIC_PROBES do
        local origin = causticOrigins[i]
        if origin then
            local t  = causticTime
            local pi = i
            local wave1 = math.sin(t * 1.1 + pi * 0.97) * 0.5 + 0.5
            local wave2 = math.sin(t * 1.7 + pi * 1.83 + 1.2) * 0.5 + 0.5
            local wave3 = math.cos(t * 0.8 + pi * 2.41) * 0.3 + 0.7
            local ci    = wave1 * wave2 * wave3
            ci          = ci * ci * 2.2

            local driftX = math.sin(t * 0.6 + pi * 1.1) * 0.8
            local driftZ = math.cos(t * 0.5 + pi * 0.9) * 0.8
            causticParts[i].CFrame = CFrame.new(origin + Vector3.new(driftX, 0, driftZ))

            causticLights[i].Color = lerpColor(
                Color3.fromRGB(30, 100, 200),
                Color3.fromRGB(200, 240, 255),
                ci
            )
            causticLights[i].Range = CFG.CAUSTIC_RANGE * (0.6 + ci * 0.5)

            local targetBright = CFG.CAUSTIC_BRIGHTNESS * ci * sunElev
            causticLights[i].Brightness = causticLights[i].Brightness +
                (targetBright - causticLights[i].Brightness) * 0.18
        else
            causticLights[i].Brightness = causticLights[i].Brightness * 0.9
        end
    end
end


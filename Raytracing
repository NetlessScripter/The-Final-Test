local function makeProbe(name, brightness, range, shadows)
    local p = Instance.new("Part")
    p.Name        = name
    p.Size        = Vector3.new(0.05, 0.05, 0.05)
    p.Anchored    = true
    p.CanCollide  = false
    p.CanQuery    = false
    p.CanTouch    = false
    p.CastShadow  = false
    p.Transparency = 1
    p.Parent      = probeRoot
    local pl = Instance.new("PointLight")
    pl.Brightness = brightness
    pl.Range      = range
    pl.Shadows    = shadows
    pl.Parent     = p
    return p, pl
end


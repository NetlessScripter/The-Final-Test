local function albedo(inst, mat)
    if inst == Workspace.Terrain then
        return TERRAIN_ALBEDO[mat] or Color3.fromRGB(140, 130, 115)
    end
    if inst and inst:IsA("BasePart") then return inst.Color end
    return Color3.fromRGB(180, 180, 180)
end

local function specularFactor(inst)
    if inst and inst:IsA("BasePart") then
        return SPECULAR_MATS[inst.Material] or 0.1
    end
    return 0.0
end

local function emissiveConfig(inst, mat)
    if inst == Workspace.Terrain then return EMISSIVE_MATS[mat] end
    if inst and inst:IsA("BasePart") then return EMISSIVE_MATS[inst.Material] end
    return nil
end

local function isTransparent(inst)
    if inst and inst:IsA("BasePart") then
        return inst.Transparency >= CFG.TRANSMIT_THRESHOLD and inst.CastShadow == false
    end
    return false
end

local function isSSS(inst)
    if inst and inst:IsA("BasePart") then
        return SSS_MATS[inst.Material] == true and inst.Transparency > 0.08
    end
    return false
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- DIRECT ILLUMINATION
--
-- Physics applied:
--   (A) Lambert NdotL: directFactor *= max(0, N·L)
--       A surface perpendicular to the sun gets zero direct light.
--
--   (B) PCSS Contact-Hardening:
--       Step 1 — Blocker search: cast one "seeker" ray to find average
--                blocker distance d_blocker.
--       Step 2 — Compute penumbra width:
--                penumbra_w = (d_blocker / PCSS_LIGHT_SIZE) × base_jitter
--                Near caster (small d_blocker) → narrow jitter → hard shadow
--                Far from caster (large d_blocker) → wide jitter → soft shadow
--
--   (C) Beer-Lambert EXPONENTIAL colored transmission through glass:
--       I_channel = I₀_channel × exp(-μ_channel)
--       μ_channel = (1 - color_channel) × opticalDensity
--       where opticalDensity = opacity × (1 + opacity)  [density proxy]
--       Chromatic: glass has slightly higher μ_blue than μ_red
--       (real dispersion — blue light absorbed/scattered more)
--
-- Returns: directFactor (0..1, shadow × NdotL), transmitColor (Color3)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function directIllumination(hitPos, hitNormal, excludeList, sunDir)

    -- ── (A) Lambert NdotL: cosine of angle between surface normal and sun
    -- Physics: irradiance on a surface = radiance × cos(θ_incidence)
    -- A surface at 90° to the sun receives zero irradiance. Period.
    local NdotL = math.max(0, hitNormal:Dot(sunDir))

    -- ── (B) PCSS — find blocker to determine penumbra radius
    local penumbraJitter
    do
        local searchOrigin = hitPos + hitNormal * CFG.SHADOW_BIAS
        local searchParams = makeParams(excludeList)
        local blocker = Workspace:Raycast(searchOrigin, sunDir * CFG.PCSS_BLOCKER_SEARCH, searchParams)
        if blocker then
            -- PCSS formula: w_penumbra = (d_receiver - d_blocker) / d_blocker × w_light
            -- We approximate d_receiver as the search distance (large, ~sun distance)
            -- So: w_penumbra ≈ (D / d_blocker) × lightSize
            -- Result: close blockers → small penumbra (hard), far blockers → large (soft)
            local dBlocker = math.max(1, blocker.Distance)
            local wPenumbra = (CFG.PCSS_BLOCKER_SEARCH / dBlocker) * CFG.PCSS_LIGHT_SIZE
            -- Convert to angular jitter for our ray-based approach
            penumbraJitter = math.clamp(wPenumbra * 0.004, 0.005, 0.22)
        else
            -- No blocker found: still need to check (geometry might be far away)
            -- Use base penumbra for sun-as-area-light
            penumbraJitter = CFG.PENUMBRA_BASE_RADIUS * 0.012
        end
    end

    -- Jitter sun direction within computed penumbra cone
    local function jitterSun()
        local jx = (rand:NextNumber() - 0.5) * penumbraJitter
        local jy = (rand:NextNumber() - 0.5) * penumbraJitter
        local jz = (rand:NextNumber() - 0.5) * penumbraJitter
        return (sunDir + Vector3.new(jx, jy, jz)).Unit
    end

    -- ── (C) Beer-Lambert shadow ray with exponential colored transmission
    local function singleShadowRay(jDir, baseExclude)
        -- Transmission starts as pure white (unattenuated)
        local tR, tG, tB = 1.0, 1.0, 1.0
        local cursor  = hitPos + hitNormal * CFG.SHADOW_BIAS
        local exclude = {}
        for _, v in ipairs(baseExclude) do table.insert(exclude, v) end

        for _ = 1, CFG.TRANSMIT_STEPS do
            local sp = makeParams(exclude)
            local sr = Workspace:Raycast(cursor, jDir * CFG.GI_BOUNCE_DISTANCE, sp)

            if not sr then
                -- Ray hit sky → fully lit, return accumulated color filter
                return 1.0, Color3.new(tR, tG, tB)
            end

            if CFG.TRANSMIT_ENABLED and isTransparent(sr.Instance) then
                -- Beer-Lambert exponential attenuation:
                -- Each channel attenuates as exp(-μ) where μ = absorption coefficient
                -- μ_channel = (1 - color_channel) × optical_density
                -- optical_density = opacity × (1 + opacity) [proxy for path length × concentration]
                local c   = sr.Instance.Color
                local op  = 1.0 - sr.Instance.Transparency       -- opacity (0=clear, 1=solid)
                local rho = op * (1.0 + op)                      -- optical density proxy

                -- Absorption: dark-colored glass absorbs more light
                -- e.g. red glass: low μ_R (passes red), high μ_G and μ_B
                local muR = (1.0 - c.R) * rho
                local muG = (1.0 - c.G) * rho
                local muB = (1.0 - c.B) * rho

                -- Chromatic dispersion: glass has slightly higher index for blue
                -- (real: n_blue > n_red → more absorption/scattering for blue)
                if CFG.TRANSMIT_CHROMATIC and sr.Instance.Material == Enum.Material.Glass then
                    muR = muR * 0.93   -- red travels further
                    muB = muB * 1.10   -- blue absorbed more
                end

                -- Exponential attenuation — this is the physically correct formula
                tR = tR * math.exp(-muR)
                tG = tG * math.exp(-muG)
                tB = tB * math.exp(-muB)

                -- Continue through this layer
                table.insert(exclude, sr.Instance)
                cursor = sr.Position + jDir * 0.05
            else
                -- Solid occluder — in shadow (transmission color stops here)
                return 0.0, Color3.new(tR, tG, tB)
            end
        end
        return 0.0, Color3.new(tR, tG, tB)
    end

    -- Accumulate multiple jittered shadow rays for soft penumbra
    if CFG.PENUMBRA_SAMPLES <= 1 then
        local di, tc = singleShadowRay(jitterSun(), excludeList)
        return di * NdotL, tc
    end

    local accumDI = 0
    local accumR, accumG, accumB = 0, 0, 0
    for _ = 1, CFG.PENUMBRA_SAMPLES do
        local di, tc = singleShadowRay(jitterSun(), excludeList)
        accumDI = accumDI + di
        accumR  = accumR  + tc.R
        accumG  = accumG  + tc.G
        accumB  = accumB  + tc.B
    end
    local n = CFG.PENUMBRA_SAMPLES
    -- Multiply averaged shadow by NdotL: surface facing away from sun → dark
    return (accumDI / n) * NdotL,
           Color3.new(accumR/n, accumG/n, accumB/n)
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- AMBIENT OCCLUSION FACTOR
--
-- Physics: samples a hemisphere of short rays from a surface point.
-- Each ray that hits nearby geometry contributes occlusion.
-- The fraction of the hemisphere blocked = how dark the point should be.
-- Cosine-weighted (rays aligned to normal contribute more) — matches
-- how a Lambertian surface integrates over incident hemisphere.
--
-- Returns: 0.0 (fully occluded) to 1.0 (fully open)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function computeAO(hitPos, hitNormal, excludeList)
    if not CFG.AO_ENABLED then return 1.0 end

    local aoParams    = makeParams(excludeList)
    local occluded    = 0.0
    local origin      = hitPos + hitNormal * 0.08

    for _ = 1, CFG.AO_RAYS do
        local dir = hemisphereDir(hitNormal)   -- cosine-weighted, so aligned rays count more
        local hit = Workspace:Raycast(origin, dir * CFG.AO_RADIUS, aoParams)
        if hit then
            -- Proximity falloff: closer geometry occludes more
            local proximity = 1.0 - (hit.Distance / CFG.AO_RADIUS)
            occluded = occluded + proximity
        end
    end

    -- Normalize and apply strength
    local aoRaw = occluded / CFG.AO_RAYS        -- 0 (open) to 1 (fully blocked)
    return 1.0 - aoRaw * CFG.AO_STRENGTH        -- remap to brightness factor
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- JITTER FOR GI IMPORTANCE SAMPLING (sun-bias)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function sunJitter(sunDir)
    local j = CFG.PENUMBRA_BASE_RADIUS * 0.05
    local jx = (rand:NextNumber() - 0.5) * j
    local jy = (rand:NextNumber() - 0.5) * j
    local jz = (rand:NextNumber() - 0.5) * j
    return (sunDir + Vector3.new(jx, jy, jz)).Unit
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- PATH TRACING KERNEL
--
-- Physics applied in this function:
--   • Sky radiance sampling when ray misses (not just fade to zero)
--   • Luminance-weighted color bleed (dark surfaces bleed little color)
--   • SSS wrap-lighting: translucent parts on shadow side get warm bleed
--   • Physical inverse-square falloff (windowed)
--   • Ambient occlusion factor multiplied into probe brightness
--   • 3rd GI bounce
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function tracePath(origin, direction, sunDir, char, probeIndex)
    local exclude = char and { char } or {}
    local params  = makeParams(exclude)

    -- Primary ray
    local hit1 = Workspace:Raycast(origin, direction * CFG.GI_BOUNCE_DISTANCE, params)

    if not hit1 then
        -- Ray escaped to sky — DON'T just fade the probe.
        -- Sample actual Rayleigh sky radiance at this direction.
        -- This makes sky-facing GI probes contribute the right color.
        local skyCol   = skyRadiance(direction, sunDir)
        local skyBright = math.max(0, sunDir.Y) * CFG.GI_BRIGHTNESS * 0.35
        local lp = giLights[probeIndex]
        lp.Color = skyCol
        lp.Brightness = lp.Brightness + (skyBright - lp.Brightness) * 0.12
        lp.Range  = CFG.GI_LIGHT_RANGE
        return
    end

    local pos1  = hit1.Position
    local nor1  = hit1.Normal
    local col1  = albedo(hit1.Instance, hit1.Material)
    local dist1 = hit1.Distance

    local ex1 = char and { char, hit1.Instance } or { hit1.Instance }

    -- Direct illumination: shadow × NdotL (both applied now — see directIllumination)
    local di1, transmitTint = directIllumination(pos1, nor1, ex1, sunDir)

    -- SSS wrap-lighting: if hit material is translucent (Glass/Neon) AND it's in shadow,
    -- simulate light bleeding through the material with a warm red-orange tint.
    -- Physics: red wavelengths travel further through organic/translucent materials
    -- than blue wavelengths (higher scattering coefficient for short wavelengths).
    local sssWrapColor = nil
    if isSSS(hit1.Instance) and di1 < 0.3 and CFG.SSS_ENABLED then
        -- Backscatter: how much the surface faces AWAY from the sun
        local backFacing = math.max(0, -nor1:Dot(sunDir))
        if backFacing > 0.05 then
            -- Warm tint: red/orange exits the shadow side of thin translucent materials
            local sssTint = Color3.fromRGB(255, 110, 55)
            local wrapStrength = backFacing * CFG.SSS_WRAP_AMOUNT
            sssWrapColor = lerpColor(col1, sssTint, wrapStrength * 0.6)
        end
    end

    -- Sun color tinted by any glass transmission
    local sunTint  = lerpColor(Lighting.ColorShift_Top, transmitTint, 0.65)
    local baseCol
    if di1 < 0.05 then
        -- Fully shadowed: ambient sky color
        baseCol = sssWrapColor or lerpColor(col1, Lighting.OutdoorAmbient, 0.5)
    elseif di1 < 0.5 then
        -- Penumbra: blend from shadow to lit
        local litCol = lerpColor(col1, sunTint, 0.28)
        local shdCol = sssWrapColor or lerpColor(col1, Lighting.OutdoorAmbient, 0.5)
        baseCol = lerpColor(shdCol, litCol, di1 * 2)
    else
        baseCol = lerpColor(col1, sunTint, 0.28)
    end

    -- ── GI BOUNCES with luminance-weighted color bleed
    -- Physics: energy conservation — a black surface (lum≈0) absorbs most light
    -- and bleeds almost no color; a bright red surface (lum≈0.3) bleeds its color.
    -- Previously: fixed bleed factor. Now: bleed ∝ surface luminance.

    local bounceDir1 = hemisphereDir(nor1)
    local params2    = makeParams(ex1)
    local hit2 = Workspace:Raycast(
        pos1 + nor1 * CFG.SHADOW_BIAS,
        bounceDir1 * (CFG.GI_BOUNCE_DISTANCE * 0.35),
        params2
    )

    local bounceColor  = baseCol
    -- di1 already contains NdotL, so bright = proportional to actual sun irradiance
    -- Add ambient floor so shadowed surfaces still get some GI contribution
    local bounceBright = CFG.GI_BRIGHTNESS * math.max(di1, 0.07)

    if hit2 then
        local col2  = albedo(hit2.Instance, hit2.Material)
        local nor2  = hit2.Normal

        -- Luminance-weighted color bleed: dark surfaces bleed little, bright surfaces bleed a lot
        local lum2      = colorLum(col2)
        local bleedAmt  = CFG.GI_COLOR_BLEED * (0.2 + lum2 * 0.8)  -- scale by surface brightness
        bounceColor = lerpColor(baseCol, col2, bleedAmt)

        -- Second bounce
        if CFG.GI_BOUNCE_COUNT >= 2 then
            local bounceDir2 = hemisphereDir(nor2)
            local ex2  = char and { char, hit1.Instance, hit2.Instance }
                             or { hit1.Instance, hit2.Instance }
            local params3 = makeParams(ex2)
            local hit3 = Workspace:Raycast(
                hit2.Position + nor2 * CFG.SHADOW_BIAS,
                bounceDir2 * (CFG.GI_BOUNCE_DISTANCE * 0.15),
                params3
            )
            if hit3 then
                local col3  = albedo(hit3.Instance, hit3.Material)
                local lum3  = colorLum(col3)
                local bleed3 = CFG.GI_COLOR_BLEED * 0.5 * (0.2 + lum3 * 0.8)
                bounceColor = lerpColor(bounceColor, col3, bleed3)

                -- Third bounce (NEW: previously only 2)
                if CFG.GI_BOUNCE_COUNT >= 3 then
                    local nor3      = hit3.Normal
                    local bounceDir3 = hemisphereDir(nor3)
                    local ex3 = char and { char, hit1.Instance, hit2.Instance, hit3.Instance }
                                     or { hit1.Instance, hit2.Instance, hit3.Instance }
                    local params4 = makeParams(ex3)
                    local hit4 = Workspace:Raycast(
                        hit3.Position + nor3 * CFG.SHADOW_BIAS,
                        bounceDir3 * (CFG.GI_BOUNCE_DISTANCE * 0.08),
                        params4
                    )
                    if hit4 then
                        local col4  = albedo(hit4.Instance, hit4.Material)
                        local lum4  = colorLum(col4)
                        bounceColor = lerpColor(bounceColor, col4,
                            CFG.GI_COLOR_BLEED * 0.22 * (0.2 + lum4 * 0.8))
                    end
                    bounceBright = bounceBright * 0.60
                end
            end
            bounceBright = bounceBright * 0.78
        end
        bounceBright = bounceBright * 0.86
    end

    -- ── PHYSICAL INVERSE-SQUARE FALLOFF (windowed)
    -- Physics: light intensity falls off as 1/r² in 3D space.
    -- The original code used (1 - d/max)² which is fake and too flat near origin.
    -- We use a windowed inverse-square: physically correct in the middle,
    -- smooth fade to 0 at max distance (avoids hard cutoff artifact).
    -- Window function: (1 - (d/dmax)⁴)² — smooth at boundary, 1 at origin
    local r        = math.max(1.0, dist1)
    local invSqRaw = 1.0 / (1.0 + r * r * (0.08 / (CFG.GI_BOUNCE_DISTANCE * 0.4)))
    local window   = math.max(0, 1.0 - (dist1 / CFG.GI_BOUNCE_DISTANCE)^4)
    window         = window * window  -- smooth at boundary
    local atten    = invSqRaw * window

    -- ── AMBIENT OCCLUSION: sample short-range hemisphere, darken corners
    local aoFactor = computeAO(pos1, nor1, ex1)

    -- ── Place probe
    local lp = giLights[probeIndex]
    local pp = giParts[probeIndex]
    pp.CFrame = CFrame.new(pos1 + nor1 * 0.35)
    lp.Color  = bounceColor

    local targetBright = bounceBright * atten * aoFactor
    lp.Brightness = lp.Brightness + (targetBright - lp.Brightness) * 0.25
    lp.Range      = CFG.GI_LIGHT_RANGE * (0.35 + atten * 0.65)
    lp.Shadows    = di1 > 0.15
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- SPECULAR RAY SYSTEM
--
-- Physics applied:
--   • Schlick Fresnel: F = F₀ + (1-F₀)(1-cosθ)⁵
--     At grazing angles (cosθ → 0) ALL surfaces approach F=1 (mirror)
--     Dielectric F₀ ≈ 0.04, metal F₀ ≈ albedo
--   • Sky radiance when reflected ray misses geometry (not flat sky color)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function updateSpecular(camCF, char, sunDir)
    local camPos  = camCF.Position
    local exclude = char and { char } or {}
    local params  = makeParams(exclude)

    for i = 1, CFG.SPEC_RAYS do
        local jx  = (rand:NextNumber() - 0.5) * 0.40
        local jy  = (rand:NextNumber() - 0.5) * 0.25
        local dir = (camCF.LookVector + camCF.RightVector * jx + camCF.UpVector * jy).Unit

        local hit = Workspace:Raycast(camPos, dir * 60, params)
        if hit then
            local sf  = specularFactor(hit.Instance)
            if sf > 0.05 then
                local nor    = hit.Normal
                local refDir = reflect(dir, nor)

                -- ── SCHLICK FRESNEL
                -- cosθ = angle between view direction and surface normal
                -- At grazing angle (parallel to surface, cosθ→0) → F approaches 1
                -- At normal incidence (perpendicular to surface, cosθ=1) → F = F₀
                local cosTheta = math.max(0, -dir:Dot(nor))
                local isMetal  = sf >= 0.85
                -- Metals: F₀ is their color (they tint reflections)
                -- Dielectrics: F₀ ≈ 0.04 for most materials
                local F0       = isMetal and sf or CFG.FRESNEL_F0_DIELECTRIC
                local fresnel  = schlickFresnel(cosTheta, F0)

                -- Cast reflected ray
                local ex2     = char and { char, hit.Instance } or { hit.Instance }
                local rParams = makeParams(ex2)
                local refHit  = Workspace:Raycast(
                    hit.Position + nor * CFG.SHADOW_BIAS,
                    refDir * (CFG.GI_BOUNCE_DISTANCE * 0.5),
                    rParams
                )

                local specColor
                if refHit then
                    -- Reflection hit geometry: blend geometry albedo with sky
                    specColor = lerpColor(
                        albedo(refHit.Instance, refHit.Material),
                        skyRadiance(refDir, sunDir), 0.35
                    )
                else
                    -- Reflection escaped to sky: sample Rayleigh sky radiance
                    -- (not flat ColorShift_Top like before)
                    specColor = skyRadiance(refDir, sunDir)
                end

                -- Roughness: rough surfaces spread the specular highlight
                local rough = 1.0 - sf
                specColor = lerpColor(specColor, albedo(hit.Instance, hit.Material),
                                      rough * CFG.SPEC_BLUR_ROUGH)

                local lp  = specLights[i]
                local pp  = specParts[i]
                pp.CFrame = CFrame.new(hit.Position + nor * 0.2)
                lp.Color  = specColor
                -- Fresnel scales specular brightness — energy conservation
                local targetBright = CFG.SPEC_BRIGHTNESS * fresnel * (1.0 - rough * 0.45)
                lp.Brightness = lp.Brightness + (targetBright - lp.Brightness) * 0.2
                lp.Range  = CFG.SPEC_RANGE
            else
                specLights[i].Brightness = specLights[i].Brightness * 0.88
            end
        else
            specLights[i].Brightness = specLights[i].Brightness * 0.88
        end
    end
end

-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
-- EMISSIVE MATERIAL SYSTEM
-- Neon parts glow. CrackedLava flickers with blackbody color.
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local sssInstances = {}
local emissiveTime = 0

local function clearSSS()
    for _, entry in ipairs(sssInstances) do
        if entry.light and entry.light.Parent then
            entry.light:Destroy()
        end
    end
    sssInstances = {}
end

local function updateSSS(char)
    clearSSS()

    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local center = root.Position
    local box    = Vector3.new(CFG.EMISSIVE_RADIUS, 16, CFG.EMISSIVE_RADIUS)
    local boxCF  = CFrame.new(center)

    local candidates = Workspace:GetPartBoundsInBox(boxCF, box)
    local count = 0

    for _, part in ipairs(candidates) do
        if count >= CFG.EMISSIVE_MAX then break end
        if part:IsA("BasePart") and not part:IsDescendantOf(probeRoot) then
            local ecfg = EMISSIVE_MATS[part.Material]
            if ecfg then
                local lightColor = ecfg.color or part.Color
                local emLight    = Instance.new("PointLight")
                emLight.Color      = lightColor
                emLight.Brightness = CFG.SSS_BRIGHTNESS * ecfg.brightness
                emLight.Range      = math.clamp(part.Size.Magnitude * 3.0, 5, 24)
                emLight.Shadows    = (part.Material == Enum.Material.CrackedLava)
                emLight.Parent     = part
                table.insert(sssInstances, { light=emLight, part=part, cfg=ecfg })
                count += 1
            end
        end
    end

    -- Scan terrain for CrackedLava voxels
    if count < CFG.EMISSIVE_MAX then
        local terrainParams = RaycastParams.new()
        terrainParams.FilterType = Enum.RaycastFilterType.Include
        terrainParams.FilterDescendantsInstances = { Workspace.Terrain }
        local steps = 6
        for i = 1, steps do
            if count >= CFG.EMISSIVE_MAX then break end
            local angle  = (i / steps) * math.pi * 2
            local offset = Vector3.new(math.cos(angle) * 12, 0, math.sin(angle) * 12)
            local tr = Workspace:Raycast(center + offset + Vector3.new(0,8,0),
                                         Vector3.new(0,-16,0), terrainParams)
            if tr and tr.Material == Enum.Material.CrackedLava then
                local lavaPart, lavaLight = makeProbe("Lava_T_"..i, 0, 20, true)
                lavaPart.CFrame  = CFrame.new(tr.Position + Vector3.new(0,1,0))
                lavaLight.Color  = Color3.fromRGB(255, 75, 8)
                lavaLight.Brightness = 3.0
                table.insert(sssInstances, {
                    light=lavaLight, part=lavaPart,
                    cfg=EMISSIVE_MATS[Enum.Material.CrackedLava], isTerrain=true
                })
                count += 1
            end
        end
    end
end

local function tickEmissiveFlicker(dt)
    emissiveTime += dt
    for idx, entry in ipairs(sssInstances) do
        if entry.cfg and entry.cfg.flicker and CFG.EMISSIVE_LAVA_FLICKER then
            local t = emissiveTime

            -- Physically-inspired blackbody flicker:
            -- Real lava/magma glows by incandescence — color depends on temperature.
            -- Cool magma: dark red (~700°C)
            -- Hot magma:  orange → yellow-orange (~1100°C)
            -- Flash peaks: near yellow-white (~1400°C+)
            -- Multi-octave noise for natural irregularity
            local slow   = math.sin(t * 0.7 + idx * 1.7) * 0.5 + 0.5
            local mid    = math.sin(t * 2.9 + idx * 2.3) * 0.35 + 0.65
            local fast   = math.sin(t * 11.3 + idx * 3.7) * 0.18 + 0.82
            -- Occasional gas-bubble flare (sharp bright spike)
            local flare  = math.max(0, math.sin(t * 7.1 + idx * 5.3)) ^ 7 * 0.55

            local heat = slow * mid * fast + flare  -- 0=cool, 1=hot

            local base = CFG.SSS_BRIGHTNESS * entry.cfg.brightness
            entry.light.Brightness = base * (0.45 + heat * 0.75)

            -- Blackbody color ramp:
            local heatColor
            if heat < 0.25 then
                -- Cool: deep red
                heatColor = lerpColor(
                    Color3.fromRGB(120, 12, 2),
                    Color3.fromRGB(230, 40, 5),
                    heat / 0.25
                )
            elseif heat < 0.60 then
                -- Mid: orange
                heatColor = lerpColor(
                    Color3.fromRGB(230, 40, 5),
                    Color3.fromRGB(255, 115, 12),
                    (heat - 0.25) / 0.35
                )
            else
                -- Hot: yellow-orange to near-white
                heatColor = lerpColor(
                    Color3.fromRGB(255, 115, 12),
                    Color3.fromRGB(255, 210, 90),
                    (heat - 0.60) / 0.40
                )
            end
            entry.light.Color = heatColor
        end
    end
end


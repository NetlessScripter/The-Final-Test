-- ADAPTIVE DEPTH OF FIELD (unchanged)
-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

local function updateDoF(camCF, exclude)
    local params  = makeParams(exclude)
    local hit     = Workspace:Raycast(camCF.Position, camCF.LookVector * CFG.DOF_MAX_RADIUS, params)
    local target  = hit and hit.Distance or CFG.DOF_MAX_RADIUS
    dof.FocusDistance = dof.FocusDistance + (target - dof.FocusDistance) * CFG.DOF_SMOOTH
    dof.InFocusRadius = math.clamp(target * 0.35, 6, CFG.DOF_FOCUS_RADIUS)
end


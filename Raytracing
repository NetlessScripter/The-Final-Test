local rand = Random.new()

local function lerpColor(a, b, t)
    t = math.clamp(t, 0, 1)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function mulColor(c, s)
    return Color3.new(
        math.clamp(c.R * s, 0, 1),
        math.clamp(c.G * s, 0, 1),
        math.clamp(c.B * s, 0, 1)
    )
end

-- Perceptual luminance (ITU-R BT.709 weights)
local function colorLum(c)
    return 0.2126 * c.R + 0.7152 * c.G + 0.0722 * c.B
end

-- Cosine-weighted hemisphere sample aligned to surface normal.
-- This is correct importance sampling for Lambertian diffuse BRDF —
-- the PDF is cos(θ)/π which cancels the cos(θ) in the rendering equation.
local function hemisphereDir(normal)
    local u1  = rand:NextNumber()
    local u2  = rand:NextNumber()
    local r   = math.sqrt(u1)
    local phi = 2 * math.pi * u2
    local x   = r * math.cos(phi)
    local z   = r * math.sin(phi)
    local y   = math.sqrt(math.max(0, 1 - u1))
    local up      = math.abs(normal.Y) < 0.99 and Vector3.new(0,1,0) or Vector3.new(1,0,0)
    local tangent  = normal:Cross(up).Unit
    local bitangent = normal:Cross(tangent).Unit
    return (tangent * x + normal * y + bitangent * z).Unit
end

-- Reflect ray around normal
local function reflect(dir, normal)
    return dir - 2 * dir:Dot(normal) * normal
end

-- Fibonacci lattice direction for uniform sphere/hemisphere coverage
local function fibDir(n, total, basis)
    local golden = (1 + math.sqrt(5)) / 2
    local theta  = 2 * math.pi * n / golden
    local cosP   = 1 - 2 * (n + 0.5) / total
    local sinP   = math.sqrt(math.max(0, 1 - cosP * cosP))
    local x = sinP * math.cos(theta)
    local y = math.abs(cosP)
    local z = sinP * math.sin(theta)
    if basis then
        return (basis.RightVector * x + basis.UpVector * y + basis.LookVector * z).Unit
    end
    return Vector3.new(x, y, z).Unit
end

-- ── SCHLICK FRESNEL APPROXIMATION
-- Physics: at grazing angles ALL surfaces become mirrors.
-- F(θ) = F₀ + (1 - F₀) × (1 - cosθ)⁵
-- F₀ = base reflectivity at normal incidence (0°)
--   Dielectrics: ~0.04  |  Metals: use albedo as F₀
-- cosθ = dot(viewDir, halfwayVector) or dot(viewDir, normal)
local function schlickFresnel(cosTheta, F0)
    local t  = math.max(0, 1 - cosTheta)
    local t5 = t * t * t * t * t   -- (1 - cosθ)⁵
    return F0 + (1 - F0) * t5
end

-- ── RAYLEIGH SKY RADIANCE
-- Physics: Rayleigh scattering ∝ 1/λ⁴ → blue scatters ~5.5× more than red.
-- This is why the sky is blue and sunsets orange/red.
-- When a GI ray escapes to sky (no geometry hit), sample this instead of nothing.
local function skyRadiance(dir, sunDir)
    local sunElev = sunDir.Y
    local sunDot  = math.max(0, dir:Dot(sunDir))
    local zenith  = math.max(0, dir.Y)  -- 0=horizon, 1=straight up

    if sunElev >= -0.05 then
        -- Daytime
        local dayT = math.min(1, math.max(0, sunElev) / 0.28)

        -- Horizon hues: warm near sun, neutral away from it
        local hR = 0.58 + sunDot * 0.38
        local hG = 0.38 + sunDot * 0.14
        local hB = 0.24 - sunDot * 0.06

        -- Zenith: Rayleigh blue, deepens at noon
        local zR = 0.16 * dayT + 0.06 * (1 - dayT)
        local zG = 0.35 * dayT + 0.12 * (1 - dayT)
        local zB = 0.90 * dayT + 0.30 * (1 - dayT)

        -- Quadratic blend horizon→zenith (matches real sky gradient shape)
        local t  = zenith * zenith
        local sR = hR + (zR - hR) * t
        local sG = hG + (zG - hG) * t
        local sB = hB + (zB - hB) * t

        -- Mie scattering: bright halo concentrated around sun disk
        local mie = sunDot ^ 9 * 0.48
        sR = sR + mie
        sG = sG + mie * 0.72

        return Color3.new(math.clamp(sR,0,1), math.clamp(sG,0,1), math.clamp(sB,0,1))
    else
        -- Night: deep blue-black
        local nT = math.clamp(-sunElev / 0.25, 0, 1)
        return Color3.new(
            math.max(0, 0.04 - nT * 0.03),
            math.max(0, 0.05 - nT * 0.04),
            math.max(0, 0.14 - nT * 0.08)
        )
    end
end

